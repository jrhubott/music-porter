# Section 11: Entry Point (Placeholder)
# ══════════════════════════════════════════════════════════════════

def main():
    """Main entry point."""
    parser = create_parser()
    args = parser.parse_args()

    # Initialize logger
    logger = Logger(verbose=args.verbose)

    logger.info(f"apple-to-ride-command v{VERSION}")
    logger.info(f"Command: {args.command or 'interactive'}")

    if args.dry_run:
        logger.info("DRY-RUN MODE: No files will be modified")

    # Route to appropriate handlers based on command
    if args.command == 'convert':
        # Convert M4A to MP3
        deps = DependencyChecker(logger)
        if not deps.check_all(require_ffmpeg=True, require_gamdl=False):
            sys.exit(1)

        output_dir = args.output or DEFAULT_EXPORT_DIR
        converter = Converter(logger)
        success = converter.convert(
            args.input_dir,
            output_dir,
            force=args.force,
            dry_run=args.dry_run,
            verbose=args.verbose
        )
        sys.exit(0 if success else 1)

    elif args.command == 'tag':
        # Update tags on existing MP3s
        deps = DependencyChecker(logger)
        if not deps.check_mutagen():
            sys.exit(1)

        tagger = TaggerManager(logger)
        success = tagger.update_tags(
            args.directory,
            new_album=args.album,
            new_artist=args.artist,
            dry_run=args.dry_run,
            verbose=args.verbose
        )
        sys.exit(0 if success else 1)

    elif args.command == 'restore':
        # Restore original tags from TXXX frames
        deps = DependencyChecker(logger)
        if not deps.check_mutagen():
            sys.exit(1)

        tagger = TaggerManager(logger)
        success = tagger.restore_tags(
            args.directory,
            restore_album=args.all or args.album,
            restore_title=args.all or args.title,
            restore_artist=args.all or args.artist,
            dry_run=args.dry_run,
            verbose=args.verbose
        )
        sys.exit(0 if success else 1)

    elif args.command == 'reset':
        # Reset tags from source M4A files
        deps = DependencyChecker(logger)
        if not deps.check_mutagen():
            sys.exit(1)

        tagger = TaggerManager(logger)
        success = tagger.reset_tags_from_source(
            args.input_dir,
            args.output_dir,
            dry_run=args.dry_run,
            verbose=args.verbose
        )
        sys.exit(0 if success else 1)

    elif args.command == 'download':
        # Download from Apple Music
        deps = DependencyChecker(logger)
        if not deps.check_gamdl():
            sys.exit(1)

        downloader = Downloader(logger, deps.venv_python)

        # Handle --playlist or --url
        if args.playlist:
            config = ConfigManager(logger=logger)
            # Try to find playlist by name or index
            playlist = None
            if args.playlist.isdigit():
                playlist = config.get_playlist_by_index(int(args.playlist) - 1)
            else:
                playlist = config.get_playlist_by_key(args.playlist)

            if not playlist:
                logger.error(f"Playlist not found: {args.playlist}")
                sys.exit(1)

            output_dir = args.output or f"{DEFAULT_MUSIC_DIR}/{playlist.key}"
            success, _, _, _ = downloader.download(
                playlist.url,
                output_dir,
                key=playlist.key,
                confirm=not args.dry_run,
                dry_run=args.dry_run
            )
            sys.exit(0 if success else 1)

        elif args.url:
            key, album_name = downloader.extract_url_info(args.url)
            output_dir = args.output or f"{DEFAULT_MUSIC_DIR}/{key}"
            success, _, _, _ = downloader.download(
                args.url,
                output_dir,
                key=key,
                confirm=not args.dry_run,
                dry_run=args.dry_run
            )
            sys.exit(0 if success else 1)

        else:
            logger.error("Either --playlist or --url must be specified")
            sys.exit(1)

    elif args.command == 'sync-usb':
        # Copy files to USB drive
        usb_manager = USBManager(logger)
        success = usb_manager.sync_to_usb(
            args.source_dir,
            usb_dir=args.usb_dir,
            dry_run=args.dry_run
        )
        sys.exit(0 if success else 1)

    elif args.command == 'pipeline':
        # Full pipeline workflow
        deps = DependencyChecker(logger)
        if not deps.check_all(require_ffmpeg=True, require_gamdl=True):
            sys.exit(1)

        config = ConfigManager(logger=logger)
        orchestrator = PipelineOrchestrator(logger, deps, config)

        # Determine what to process
        if args.auto:
            # Process all playlists
            logger.info("Auto mode: processing all playlists")

            # Create aggregate statistics tracker
            aggregate_stats = AggregateStatistics()

            for i, playlist in enumerate(config.playlists):
                logger.info(f"\n{'=' * 70}")
                logger.info(f"Processing playlist {i+1}/{len(config.playlists)}: {playlist.name}")
                logger.info(f"{'=' * 70}")

                success = orchestrator.run_full_pipeline(
                    playlist=str(i + 1),
                    auto=True,
                    copy_to_usb=args.copy_to_usb,
                    usb_dir=args.usb_dir,
                    dry_run=args.dry_run,
                    verbose=args.verbose
                )

                # Collect statistics from this run
                aggregate_stats.add_playlist_result(orchestrator.stats)

            # Print aggregate summary (only for multiple playlists)
            if len(config.playlists) > 1:
                orchestrator._print_aggregate_summary(aggregate_stats)

            sys.exit(0 if aggregate_stats.failed_playlists == 0 else 1)

        elif args.playlist or args.url:
            # Process specific playlist or URL
            success = orchestrator.run_full_pipeline(
                playlist=args.playlist,
                url=args.url,
                auto=False,
                copy_to_usb=args.copy_to_usb,
                usb_dir=args.usb_dir,
                dry_run=args.dry_run,
                verbose=args.verbose
            )
            sys.exit(0 if success else 1)

        else:
            logger.error("For pipeline command, specify --playlist, --url, or --auto")
            sys.exit(1)

    else:
        # No command specified - show interactive menu
        deps = DependencyChecker(logger)
        if not deps.check_all(require_ffmpeg=True, require_gamdl=True):
            sys.exit(1)

        config = ConfigManager(logger=logger)
        menu = InteractiveMenu(logger, config, deps)

        success = menu.show(dry_run=args.dry_run, verbose=args.verbose)
        sys.exit(0 if success else 1)


if __name__ == "__main__":
    main()
