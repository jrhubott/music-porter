class DownloadStatistics:
    """Tracks download operation statistics."""

    def __init__(self):
        self.playlist_total = 0      # Total tracks in playlist
        self.downloaded = 0          # Newly downloaded tracks
        self.skipped = 0             # Already existed
        self.failed = 0              # Failed downloads


class Converter:
    """Manages M4A to MP3 conversion with tag preservation."""

    def __init__(self, logger=None, cleanup_options=None):
        self.logger = logger or Logger()
        self.cleanup_options = cleanup_options or {
            "remove_id3v1": True,
            "use_id3v23": True,
            "remove_duplicates": True
        }
        self.stats = ConversionStatistics()
        self.tag_stats = TagStatistics()

    def _sanitize_filename(self, name):
        """Remove invalid filename characters."""
        invalid_chars = r'\/:*?"<>|'
        return "".join(c for c in name if c not in invalid_chars)

    def convert(self, input_dir, output_dir, force=False, dry_run=False, verbose=False):
        """
        Recursively scan input_dir for .m4a files, convert them to MP3
        using ffmpeg, and save all output files flat into output_dir.
        Tags are written immediately after each conversion.
        """
        from mutagen.mp4 import MP4
        from mutagen.id3 import ID3, TIT2, TPE1, TALB, ID3NoHeaderError

        start_time = time.time()

        input_path = Path(input_dir)
        output_path = Path(output_dir)

        if input_path.resolve() == output_path.resolve():
            self.logger.error("Input and output directories cannot be the same")
            return False

        # Find all M4A files recursively
        m4a_files = [
            f for f in input_path.rglob("*.m4a")
            if not f.name.startswith('._')
        ]

        if not m4a_files:
            self.logger.info(f"No .m4a files found in '{input_dir}'")
            return True

        self.stats.total_found = len(m4a_files)
        self.logger.info(f"Found {self.stats.total_found} .m4a file(s) (recursive)")
        self.logger.info(f"Output directory: '{output_dir}' (flat)")

        if force:
            self.logger.info("Force mode enabled — existing files will be overwritten")

        if not dry_run:
            output_path.mkdir(parents=True, exist_ok=True)

        count = 0
        for input_file in m4a_files:
            count += 1
            display_name = input_file.relative_to(input_path)

            self.logger.info(f"[{count}/{self.stats.total_found}] Processing: {display_name}")

            try:
                # Read M4A tags
                m4a = MP4(str(input_file))
                title  = str(m4a.tags.get('\xa9nam', ['Unknown Title'])[0])
                artist = str(m4a.tags.get('\xa9ART', ['Unknown Artist'])[0])
                album  = str(m4a.tags.get('\xa9alb', ['Unknown Album'])[0])

                # Create output filename
                safe_title = self._sanitize_filename(title)
                safe_artist = self._sanitize_filename(artist)
                output_filename = f"{safe_artist} - {safe_title}.mp3"
                output_file = output_path / output_filename
                already_exists = output_file.exists()

                # ── Preserve existing TXXX frames before ffmpeg overwrites file ──
                preserved_txxx = {}
                if already_exists and force:
                    try:
                        existing_tags = ID3(str(output_file))
                        preserved_txxx['OriginalTitle'] = _get_txxx(existing_tags, 'OriginalTitle')
                        preserved_txxx['OriginalArtist'] = _get_txxx(existing_tags, 'OriginalArtist')
                        preserved_txxx['OriginalAlbum'] = _get_txxx(existing_tags, 'OriginalAlbum')
                        if any(preserved_txxx.values()):
                            self.logger.info(f"Preserving existing original tags from '{output_filename}'")
                    except ID3NoHeaderError:
                        pass  # No existing tags to preserve

                if already_exists and not force:
                    self.logger.skip(f"Already exists: '{output_filename}'")
                    self.stats.skipped += 1
                    continue

                if verbose:
                    self.logger.debug(f"Source file:  '{input_file}'")
                    self.logger.debug(f"File size:    {input_file.stat().st_size / 1024:.1f} KB")
                    if already_exists and force:
                        self.logger.debug(f"Force flag set — overwriting: '{output_filename}'")
                    self.logger.debug(f"Source tags:")
                    self.logger.debug(f"  → Title:  '{title}'")
                    self.logger.debug(f"  → Artist: '{artist}'")
                    self.logger.debug(f"  → Album:  '{album}'")

                if dry_run:
                    if already_exists and force:
                        self.logger.dry_run(f"Would overwrite: '{output_filename}'")
                    else:
                        self.logger.dry_run(f"Would convert:   '{display_name}'")
                    self.logger.dry_run(f"  → Output:     '{output_filename}'")
                    self.logger.dry_run(f"  → Title:      '{artist} - {title}'")
                    self.logger.dry_run(f"  → Artist:     '{artist}'")
                    self.logger.dry_run(f"  → Album:      '{album}'")
                    continue

                # Run ffmpeg conversion
                cmd = [
                    "ffmpeg", "-y", "-i", str(input_file),
                    "-codec:a", "libmp3lame", "-q:a", FFMPEG_QUALITY,
                    str(output_file)
                ]
                subprocess.run(cmd, capture_output=True, check=True)

                # Write ID3 tags
                try:
                    tags = ID3(str(output_file))
                except ID3NoHeaderError:
                    tags = ID3()

                tags["TIT2"] = TIT2(encoding=3, text=title)
                tags["TPE1"] = TPE1(encoding=3, text=artist)
                tags["TALB"] = TALB(encoding=3, text=album)

                # ── Restore preserved TXXX frames BEFORE save_original_tag() runs ──
                if preserved_txxx.get('OriginalTitle'):
                    from mutagen.id3 import TXXX
                    tags.add(TXXX(encoding=3, desc='OriginalTitle', text=preserved_txxx['OriginalTitle']))
                if preserved_txxx.get('OriginalArtist'):
                    from mutagen.id3 import TXXX
                    tags.add(TXXX(encoding=3, desc='OriginalArtist', text=preserved_txxx['OriginalArtist']))
                if preserved_txxx.get('OriginalAlbum'):
                    from mutagen.id3 import TXXX
                    tags.add(TXXX(encoding=3, desc='OriginalAlbum', text=preserved_txxx['OriginalAlbum']))

                # ── Store originals FIRST — hard gate prevents overwrite ──
                r_title, title_was_stored = save_original_tag(
                    tags, "TXXX:OriginalTitle", "OriginalTitle",
                    title, "title", self.logger)
                r_artist, artist_was_stored = save_original_tag(
                    tags, "TXXX:OriginalArtist", "OriginalArtist",
                    artist, "artist", self.logger)
                r_album, album_was_stored = save_original_tag(
                    tags, "TXXX:OriginalAlbum", "OriginalAlbum",
                    album, "album", self.logger)

                if title_was_stored:
                    self.tag_stats.title_stored += 1
                else:
                    self.tag_stats.title_protected += 1
                if artist_was_stored:
                    self.tag_stats.artist_stored += 1
                else:
                    self.tag_stats.artist_protected += 1
                if album_was_stored:
                    self.tag_stats.album_stored += 1
                else:
                    self.tag_stats.album_protected += 1

                # ── Update Title AFTER originals are safely stored ────
                if update_title_tag(tags, self.cleanup_options,
                                   self.logger, dry_run=dry_run, verbose=verbose):
                    self.tag_stats.title_updated += 1

                _apply_cleanup(tags, str(output_file), self.cleanup_options)

                if verbose:
                    final_title = str(tags["TIT2"]) if "TIT2" in tags else ""
                    self.logger.debug(f"Tags AFTER conversion:")
                    self.logger.debug(f"  → Title:          '{final_title}'")
                    self.logger.debug(f"  → Artist:         '{artist}'")
                    self.logger.debug(f"  → Album:          '{album}'")
                    self.logger.debug(f"  → OriginalTitle:  '{title}'")
                    self.logger.debug(f"  → OriginalArtist: '{artist}'")
                    self.logger.debug(f"  → OriginalAlbum:  '{album}'")
                    self.logger.debug(f"Output size:  {output_file.stat().st_size / 1024:.1f} KB")

                if already_exists and force:
                    self.logger.ok(f"Overwritten and tagged → '{output_filename}'")
                    self.stats.overwritten += 1
                else:
                    self.logger.ok(f"Converted and tagged → '{output_filename}'")
                    self.stats.converted += 1

            except Exception as e:
                self.logger.error(f"Failed to convert '{display_name}': {e}")
                self.stats.errors += 1

        duration = time.time() - start_time
        self._print_summary(input_dir, output_dir, duration)

        return self.stats.errors == 0

    def _print_summary(self, input_dir, output_dir, duration):
        """Print conversion summary statistics."""
        print(f"\n{'=' * 60}")
        print(f"  CONVERSION SUMMARY")
        print(f"{'=' * 60}")
        print(f"  Run date:                {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        print(f"  Input directory:         '{input_dir}'")
        print(f"  Output directory:        '{output_dir}'")
        print(f"  Duration:                {duration:.1f}s")
        print(f"{'─' * 60}")
        print(f"  FILES")
        print(f"{'─' * 60}")
        print(f"  Total found:             {self.stats.total_found}")
        print(f"  Converted:               {self.stats.converted}")
        print(f"  Overwritten:             {self.stats.overwritten}")
        print(f"  Skipped (exists):        {self.stats.skipped}")
        print(f"  Errors:                  {self.stats.errors}")
        print(f"{'─' * 60}")
        print(f"  TAGGING")
        print(f"{'─' * 60}")
        print(f"  Title updated:           {self.tag_stats.title_updated}")
        print(f"  OriginalTitle stored:    {self.tag_stats.title_stored}")
        print(f"  OriginalArtist stored:   {self.tag_stats.artist_stored}")
        print(f"  OriginalAlbum stored:    {self.tag_stats.album_stored}")
        print(f"  OriginalTitle protected: {self.tag_stats.title_protected}")
        print(f"  OriginalArtist protected:{self.tag_stats.artist_protected}")
        print(f"  OriginalAlbum protected: {self.tag_stats.album_protected}")
        print(f"{'─' * 60}")
        if self.stats.errors > 0:
            print(f"  Status:                  ⚠️  Completed with errors")
        elif self.stats.skipped == self.stats.total_found:
            print(f"  Status:                  ℹ️  Nothing to do — all files already exist")
        else:
            print(f"  Status:                  ✅ Completed successfully")
        print(f"{'=' * 60}")


