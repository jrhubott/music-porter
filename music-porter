    elif r.action == "update":
        print(f"  Updated:                 {r.files_modified}")
        print(f"  Errors:                  {r.errors}")
    elif r.action == "strip":
        print(f"  Stripped:                {r.files_modified}")
        print(f"  Skipped (no art):        {r.files_skipped}")
        print(f"  Errors:                  {r.errors}")
    elif r.action == "resize":
        print(f"  Resized:                 {r.files_modified}")
        print(f"  Skipped (already small): {r.files_skipped}")
        print(f"  Skipped (no art):        {r.no_source}")
        print(f"  Errors:                  {r.errors}")
        if r.total_before > 0:
            def fmt_sz(b):
                if b >= 1024 * 1024:
                    return f"{b / (1024 * 1024):.1f} MB"
                return f"{b / 1024:.1f} KB"
            print(f"{'─' * 60}")
            if r.total_after > 0:
                print(f"  Total cover art:         {fmt_sz(r.total_before)} → {fmt_sz(r.total_after)}")
            else:
                print(f"  Total cover art:         {fmt_sz(r.total_before)}")

    print(f"{'=' * 60}")


def render_pipeline_summary(r: PipelineResult) -> None:
    """Render pipeline summary as 70-char-wide console box."""
    print(f"\n{'=' * 70}")
    print("  PIPELINE SUMMARY")
    print(f"{'=' * 70}")
    print(f"  Run date:                {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Playlist:                {r.playlist_name or '—'} ({r.playlist_key or '—'})")
    print(f"  Duration:                {r.duration:.1f}s")

    # Download stage
    if "download" in r.stages_completed or "download" in r.stages_failed or "download" in r.stages_skipped:
        print(f"{'─' * 70}")
        print("  DOWNLOAD STAGE")
        print(f"{'─' * 70}")
        if "download" in r.stages_completed and r.download_result:
            d = r.download_result
            if d.playlist_total > 0:
                print(f"  Total tracks in playlist:{d.playlist_total}")
            print(f"  Downloaded (new):        {d.downloaded}")
            print(f"  Skipped (already exist): {d.skipped}")
            if d.failed > 0:
                print(f"  Failed:                  {d.failed}")
            print("  Status:                  ✅ Success")
        elif "download" in r.stages_completed:
            print("  Status:                  ✅ Success")
        elif "download" in r.stages_skipped:
            print("  Status:                  ⏭️  Skipped")
        else:
            print("  Status:                  ❌ Failed")

    # Conversion stage
    if r.conversion_result or "convert" in r.stages_failed:
        print(f"{'─' * 70}")
        print("  CONVERSION STAGE")
        print(f"{'─' * 70}")
        if r.conversion_result:
            cr = r.conversion_result
            print(f"  Files converted:         {cr.converted}")
            print(f"  Files overwritten:       {cr.overwritten}")
            print(f"  Files skipped:           {cr.skipped}")
            print(f"  Conversion errors:       {cr.errors}")
            if cr.success:
                print("  Status:                  ✅ Success")
            else:
                print("  Status:                  ❌ Failed")
        elif "convert" in r.stages_failed:
            print("  Status:                  ❌ Failed")

    # Tagging stage
    if r.tag_result or "tag" in r.stages_failed:
        print(f"{'─' * 70}")
        print("  TAGGING STAGE")
        print(f"{'─' * 70}")
        if r.tag_result:
            tr = r.tag_result
            if r.tagging_album:
                print(f"  Album set to:            {r.tagging_album}")
            if r.tagging_artist:
                print(f"  Artist set to:           {r.tagging_artist}")
            print(f"  Title updated:           {tr.title_updated}")
            print(f"  Album updated:           {tr.album_updated}")
            print(f"  Artist updated:          {tr.artist_updated}")
            print(f"  OriginalTitle stored:    {tr.title_stored}")
            print(f"  OriginalArtist stored:   {tr.artist_stored}")
            print(f"  OriginalAlbum stored:    {tr.album_stored}")
            if r.cover_art_embedded > 0 or r.cover_art_missing > 0:
                print(f"  Cover art embedded:      {r.cover_art_embedded}")
                print(f"  Cover art missing:       {r.cover_art_missing}")
            if tr.success:
                print("  Status:                  ✅ Success")
            else:
                print("  Status:                  ❌ Failed")
        elif "tag" in r.stages_failed:
            print("  Status:                  ❌ Failed")

    # USB sync stage
    if r.usb_result or "usb-sync" in r.stages_failed:
        print(f"{'─' * 70}")
        print("  USB SYNC STAGE")
        print(f"{'─' * 70}")
        if r.usb_result and r.usb_result.success:
            print("  Status:                  ✅ Success")
            if r.usb_destination:
                print(f"  USB destination:         {r.usb_destination}")
        else:
            print("  Status:                  ❌ Failed")

    # Comprehensive file summary
    if len(r.stages_completed) > 0:
        print(f"{'─' * 70}")
        print("  COMPREHENSIVE FILES SUMMARY")
        print(f"{'─' * 70}")

        if r.download_result:
            d = r.download_result
            if d.playlist_total > 0:
                print(f"  Playlist tracks:         {d.playlist_total}")
            total_after_download = d.downloaded + d.skipped
            print(f"  M4A files after download:{total_after_download} "
                  f"({d.downloaded} new, {d.skipped} existing)")

        if r.conversion_result:
            c = r.conversion_result
            total_processed = c.converted + c.overwritten + c.skipped
            print(f"  MP3s after conversion:   {total_processed} "
                  f"({c.converted + c.overwritten} converted, {c.skipped} skipped)")

        if r.tag_result:
            t = r.tag_result
            print(f"  Tags updated:            {t.title_updated}")
            total_original_stored = t.title_stored + t.artist_stored + t.album_stored
            if total_original_stored > 0:
                print(f"  Original tags stored:    {total_original_stored}")
            if r.cover_art_embedded > 0 or r.cover_art_missing > 0:
                print(f"  Cover art embedded:      {r.cover_art_embedded}")
                if r.cover_art_missing > 0:
                    print(f"  Cover art missing:       {r.cover_art_missing}")

        if r.usb_result and r.usb_result.success and r.conversion_result:
            files_on_usb = r.conversion_result.converted + r.conversion_result.overwritten + r.conversion_result.skipped
            print(f"  Files copied to USB:     {files_on_usb}")

    # Overall status
    print(f"{'─' * 70}")
    if len(r.stages_failed) == 0:
        print("  Status:                  ✅ Completed successfully")
    else:
        print("  Status:                  ⚠️  Completed with errors")
        print(f"  Failed stages:           {', '.join(r.stages_failed)}")
    print(f"{'=' * 70}")


def render_aggregate_summary(r: AggregateResult) -> None:
    """Render aggregate summary for multiple playlists as 70-char-wide console box."""
    duration_mins = int(r.duration // 60)
    duration_secs = int(r.duration % 60)

    print(f"\n{'=' * 70}")
    print("  TOTAL SUMMARY - ALL PLAYLISTS")
    print(f"{'=' * 70}")
    print(f"  Playlists processed:     {r.total_playlists}")
    print(f"  Total duration:          {r.duration:.1f}s ({duration_mins}m {duration_secs}s)")

    if r.failed_playlists == 0:
        print("  Overall status:          ✅ All succeeded")
    else:
        print("  Overall status:          ⚠️  Some failed")

    # Playlist results table
    print(f"{'─' * 70}")
    print("  PLAYLIST RESULTS")
    print(f"{'─' * 70}")
    print(f"  {'Playlist':<24} {'Downloaded':<12} {'Converted':<11} {'Tagged':<8} Status")
    print(f"  {'─' * 70}")

    for pr in r.playlist_results:
        # Format download stats
        if hasattr(pr, 'download_result') and pr.download_result:
            dl_str = f"{pr.download_result.downloaded}/{pr.download_result.playlist_total}"
        elif hasattr(pr, 'download_stats') and pr.download_stats:
            dl_str = f"{pr.download_stats.downloaded}/{pr.download_stats.playlist_total}"
        elif hasattr(pr, 'failed_stage') and pr.failed_stage == "download":
            dl_str = "ERROR"
        else:
            dl_str = "-/-"

        # Format conversion stats
        if hasattr(pr, 'conversion_result') and pr.conversion_result:
            cr = pr.conversion_result
            conv_count = cr.converted + cr.overwritten
            conv_total = conv_count + cr.skipped
            conv_str = f"{conv_count}/{conv_total}"
        elif hasattr(pr, 'conversion_stats') and pr.conversion_stats:
            cs = pr.conversion_stats
            conv_count = cs.converted + cs.overwritten
            conv_total = conv_count + cs.skipped
            conv_str = f"{conv_count}/{conv_total}"
        elif hasattr(pr, 'failed_stage') and pr.failed_stage in ["download", "convert"]:
            conv_str = "-/-"
        else:
            conv_str = "0/0"

        # Format tag stats
        if hasattr(pr, 'tag_result') and pr.tag_result:
            tag_str = str(pr.tag_result.title_updated)
        elif hasattr(pr, 'tagging_stats') and pr.tagging_stats:
            tag_str = str(pr.tagging_stats.title_updated)
        else:
            tag_str = "-"

        # Status
        if pr.success:
            status = "✅ Success"
        else:
            failed = getattr(pr, 'failed_stage', 'Failed') or 'Failed'
            status = f"❌ {failed}"

        name = getattr(pr, 'playlist_name', None) or getattr(pr, 'name', '?')
        display_name_str = name[:22] if len(name) > 22 else name

        print(f"  {display_name_str:<24} {dl_str:<12} {conv_str:<11} {tag_str:<8} {status}")

    # Totals
    totals = r.cumulative_stats
    print(f"  {'─' * 70}")
    total_dl = f"{totals.get('downloaded', 0)}/{totals.get('playlist_total', 0)}"
    total_conv = f"{totals.get('converted', 0) + totals.get('overwritten', 0)}/{totals.get('converted', 0) + totals.get('overwritten', 0) + totals.get('skipped_conversion', 0)}"
    success_ratio = f"✅ {r.successful_playlists}/{r.total_playlists}"

    print(f"  {'TOTALS':<24} {total_dl:<12} {total_conv:<11} {totals.get('title_updated', 0):<8} {success_ratio}")

    # Cumulative statistics
    print(f"{'─' * 70}")
    print("  CUMULATIVE STATISTICS")
    print(f"{'─' * 70}")
    print(f"  Total tracks in playlists:    {totals.get('playlist_total', 0)}")
    print()
    print("  Downloads:")
    print(f"    New downloads:              {totals.get('downloaded', 0)}")
    print(f"    Already existed (skipped):  {totals.get('skipped_download', 0)}")
    if totals.get('failed_download', 0) > 0:
        print(f"    Failed:                     {totals['failed_download']}")
    print()
    print("  Conversions:")
    print(f"    Newly converted:            {totals.get('converted', 0)}")
    if totals.get('overwritten', 0) > 0:
        print(f"    Overwritten:                {totals['overwritten']}")
    print(f"    Skipped (already exist):    {totals.get('skipped_conversion', 0)}")
    if totals.get('errors_conversion', 0) > 0:
        print(f"    Errors:                     {totals['errors_conversion']}")
    print()
    print("  Tag Operations:")
    print(f"    Titles updated:             {totals.get('title_updated', 0)}")
    if totals.get('original_tags_stored', 0) > 0:
        print(f"    Original tags stored:       {totals['original_tags_stored']}")

    # USB sync
    if r.usb_destination and totals.get('files_on_usb', 0) > 0:
        print()
        print("  USB Sync:")
        print(f"    Files copied to USB:        {totals['files_on_usb']}")
        print(f"    Destination:                {r.usb_destination}")

    # Final status
    print(f"{'─' * 70}")
    if r.failed_playlists == 0:
        print("  STATUS:  ✅ All playlists completed successfully")
    else:
        print(f"  STATUS:  ⚠️  {r.failed_playlists} of {r.total_playlists} playlists failed")
        failed_names = [
            f"{getattr(pr, 'playlist_name', None) or getattr(pr, 'name', '?')} ({getattr(pr, 'failed_stage', '?')})"
            for pr in r.playlist_results
            if not pr.success
        ]
        if failed_names:
            print(f"  Failed:  {', '.join(failed_names)}")

    print(f"{'=' * 70}")


def render_dependency_check(r: DependencyCheckResult, config=None) -> None:
    """Render dependency check summary."""
    print("\n  ── Dependencies ──")

    if r.venv_active:
        venv_display = r.venv_path
        if venv_display:
            from pathlib import Path as _Path
            venv_display = venv_display.replace(str(_Path.home()), '~')
        else:
            venv_display = 'active'
        print(f"  Python:   ✓ venv ({venv_display})")
    else:
        print("  Python:   ⚠ No virtual environment")

    if r.packages:
        installed = [pkg for pkg, ok in r.packages.items() if ok]
        missing = [pkg for pkg, ok in r.packages.items() if not ok]
        if not missing:
            pkg_list = ', '.join(installed)
            print(f"  Packages: ✓ {pkg_list}")
        else:
            print(f"  Packages: ⚠ Missing: {', '.join(missing)}")

    if r.ffmpeg_available:
        print("  System:   ✓ ffmpeg")
    else:
        print("  System:   ⚠ ffmpeg not found")

    if config:
        count = len(config.playlists)
        print(f"  Config:   ✓ {count} playlist{'s' if count != 1 else ''} loaded")

    print()



