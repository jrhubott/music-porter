#!/usr/bin/env python3
"""
music-porter - Apple Music to MP3 converter and sync server

Server-only entry point. All functionality is accessed via the web
dashboard and REST API. Business logic lives in server/core/ modules,
Flask routes in server/web_api.py + server/web_ui.py.
"""

from __future__ import annotations

import argparse
import os
import platform
import sys
from pathlib import Path


# ── Auto-activate venv ──
# If a .venv exists but we're running under system Python, re-exec with venv Python.
def _auto_activate_venv():
    """Re-launch this script under .venv/bin/python if available."""
    # sys.prefix != sys.base_prefix is Python's own way to detect a venv
    if sys.prefix != sys.base_prefix:
        return  # Already running inside a venv
    if '--no-venv' in sys.argv:
        return  # Docker / manual override — skip venv activation

    if platform.system() == 'Windows':
        venv_python = Path('.venv/Scripts/python.exe')
    else:
        venv_python = Path('.venv/bin/python')

    if not venv_python.exists():
        return  # No venv to activate

    # Use absolute path (not realpath) so Python finds pyvenv.cfg via the venv path
    venv_python_abs = str(venv_python.absolute())
    os.execv(venv_python_abs, [venv_python_abs, *sys.argv])

_auto_activate_venv()

# Add server/ to sys.path so server modules are importable without package prefix
sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), 'server'))

from core.porter_core import (
    VERSION,
    DependencyChecker,
    Logger,
    _init_third_party,
    migrate_config_schema,
    migrate_data_dir,
    migrate_db_schema,
    migrate_profiles_schema,
)


def _create_parser():
    """Create the argument parser for server mode."""
    parser = argparse.ArgumentParser(
        prog='music-porter',
        description='Music Porter — Apple Music to MP3 converter and sync server',
        epilog='Start the server, then open the web dashboard in a browser.',
    )

    parser.add_argument('--version', action='version',
                        version=f'%(prog)s {VERSION}')
    parser.add_argument('--no-venv', action='store_true',
                        help='Skip virtual environment detection')

    # Server subcommand (the only command now)
    subparsers = parser.add_subparsers(dest='command', help='Available commands')

    server_parser = subparsers.add_parser('server',
        help='Start the Music Porter server (default)')
    server_parser.add_argument('--host', default='0.0.0.0',
        help='Host to bind (default: 0.0.0.0)')
    server_parser.add_argument('--port', type=int, default=5555,
        help='Port to bind (default: 5555)')
    server_parser.add_argument('--show-api-key', action='store_true',
        dest='show_api_key', help='Display the API key on startup')
    server_parser.add_argument('--no-bonjour', action='store_true',
        dest='no_bonjour', help='Disable Bonjour/mDNS service advertisement')
    server_parser.add_argument('--behind-proxy', action='store_true',
        help='Trust X-Forwarded-* headers from a reverse proxy')
    server_parser.add_argument('--proxy-count', type=int, default=1,
        help='Number of trusted proxy hops (default: 1)')

    return parser


def main():
    """Main entry point — starts the Music Porter server."""
    # Fast path: --version needs no config or dependency checks
    if '--version' in sys.argv:
        print(f"music-porter {VERSION}")
        sys.exit(0)

    temp_logger = Logger(verbose=False)

    # Create data directory and migrate legacy files from project root
    migration_events = migrate_data_dir(temp_logger)

    # Ensure Python packages are installed before config loading.
    # If missing, installs from requirements.txt and re-execs.
    if '--no-venv' not in sys.argv:
        bootstrap_deps = DependencyChecker(temp_logger)
        if not bootstrap_deps.check_python_packages():
            temp_logger.error("Failed to install required Python packages")
            sys.exit(1)
    else:
        _init_third_party()

    # Apply schema migrations before any DB or config class is instantiated
    migration_events += migrate_db_schema(logger=temp_logger)
    migration_events += migrate_config_schema(logger=temp_logger)
    migration_events += migrate_profiles_schema(logger=temp_logger)

    parser = _create_parser()
    args = parser.parse_args()

    # Default to 'server' if no command specified
    if not args.command:
        args.command = 'server'
        args.host = '0.0.0.0'
        args.port = 5555
        args.show_api_key = False
        args.no_bonjour = False
        args.behind_proxy = False
        args.proxy_count = 1

    # Store migration events for the web app to flush into audit trail
    import web_ui
    web_ui._migration_events = migration_events

    # Start the server
    try:
        web_ui.start_server(
            host=args.host,
            port=args.port,
            no_auth=False,
            show_api_key=args.show_api_key,
            enable_bonjour=not args.no_bonjour,
            behind_proxy=args.behind_proxy,
            proxy_count=args.proxy_count,
        )
    except ImportError as e:
        temp_logger.error(f"Server requires Flask: {e}")
        temp_logger.info("Install with: pip install flask")
        sys.exit(1)


if __name__ == "__main__":
    main()
