#!/bin/bash
set -euo pipefail

die() { echo "ERROR: $*" >&2; exit 1; }

command -v git >/dev/null 2>&1 || die "git not found"
command -v docker >/dev/null 2>&1 || die "docker not found"
git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [[ $# -gt 0 && "$1" != "$CURRENT_BRANCH" ]]; then
    echo "Branch: $CURRENT_BRANCH -> $1"
    git checkout "$1" || die "git checkout $1 failed (check for uncommitted changes)"
else
    echo "Branch: $CURRENT_BRANCH"
fi

docker compose down || true
git pull --rebase || die "git pull --rebase failed"
docker compose build || die "docker compose build failed"
docker compose up
