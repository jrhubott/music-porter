def restore_tags(directory, restore_album=False, restore_title=False,
                 restore_artist=False, cleanup_options=None,
                 dry_run=False, verbose=False):
    """
    Recursively restore original tags for all MP3s under a directory
    by reading values from TXXX:OriginalTitle / OriginalArtist /
    OriginalAlbum tags. [1]
    """
    from mutagen.id3 import ID3, TALB, TIT2, TPE1, ID3NoHeaderError

    start_time = time.time()

    if cleanup_options is None:
        cleanup_options = {
            "remove_id3v1":      True,
            "use_id3v23":        True,
            "remove_duplicates": True
        }

    if not os.path.isdir(directory):
        print(f"[ERROR] Directory '{directory}' not found.")
        return

    mp3_files = [
        os.path.join(root, f)
        for root, dirs, files in os.walk(directory)
        for f in files
        if f.lower().endswith('.mp3')
    ]

    if not mp3_files:
        print(f"[INFO] No MP3 files found in '{directory}' "
              f"or its subdirectories.")
        return

    total = len(mp3_files)
    print(f"[INFO] Found {total} MP3 file(s) in '{directory}' (recursive).")
    print(f"[INFO] Restoring Album:  {restore_album}")
    print(f"[INFO] Restoring Title:  {restore_title}")
    print(f"[INFO] Restoring Artist: {restore_artist}")
    if dry_run:
        print("[DRY-RUN] No files will be modified.\n")

    count    = 0
    restored = 0
    skipped  = 0
    errors   = 0

    tags_title_restored  = 0
    tags_artist_restored = 0
    tags_album_restored  = 0
    tags_title_missing   = 0
    tags_artist_missing  = 0
    tags_album_missing   = 0

    for filepath in mp3_files:
        count += 1
        filename = os.path.relpath(filepath, directory)

        print(f"\n[{count}/{total}] Processing: '{filename}'")

        try:
            try:
                tags = ID3(filepath)
            except ID3NoHeaderError:
                print(f"  [WARN] No ID3 tags found in '{filename}'. Skipping.")
                skipped += 1
                continue

            orig_title  = _get_txxx(tags, "OriginalTitle")
            orig_artist = _get_txxx(tags, "OriginalArtist")
            orig_album  = _get_txxx(tags, "OriginalAlbum")

            if verbose:
                print(f"  [VERBOSE] Preserved originals:")
                print(f"            → OriginalTitle:  '{orig_title}'")
                print(f"            → OriginalArtist: '{orig_artist}'")
                print(f"            → OriginalAlbum:  '{orig_album}'")
                print(f"  [VERBOSE] Tags BEFORE restore:")
                print(f"            → Title:  "
                      f"'{str(tags['TIT2']) if 'TIT2' in tags else ''}'")
                print(f"            → Artist: "
                      f"'{str(tags['TPE1']) if 'TPE1' in tags else ''}'")
                print(f"            → Album:  "
                      f"'{str(tags['TALB']) if 'TALB' in tags else ''}'")

            file_restored = False

            if restore_title:
                if orig_title:
                    if dry_run:
                        print(f"  [DRY-RUN] Would restore Title:  → '{orig_title}'")
                    else:
                        tags["TIT2"] = TIT2(encoding=3, text=orig_title)
                        print(f"  Title  restored → '{orig_title}'")
                        tags_title_restored += 1
                        file_restored = True
                else:
                    print(f"  [SKIP] No OriginalTitle for '{filename}'.")
                    tags_title_missing += 1

            if restore_artist:
                if orig_artist:
                    if dry_run:
                        print(f"  [DRY-RUN] Would restore Artist: → '{orig_artist}'")
                    else:
                        tags["TPE1"] = TPE1(encoding=3, text=orig_artist)
                        print(f"  Artist restored → '{orig_artist}'")
                        tags_artist_restored += 1
                        file_restored = True
                else:
                    print(f"  [SKIP] No OriginalArtist for '{filename}'.")
                    tags_artist_missing += 1

            if restore_album:
                if orig_album:
                    if dry_run:
                        print(f"  [DRY-RUN] Would restore Album:  → '{orig_album}'")
                    else:
                        tags["TALB"] = TALB(encoding=3, text=orig_album)
                        print(f"  Album  restored → '{orig_album}'")
                        tags_album_restored += 1
                        file_restored = True
                else:
                    print(f"  [SKIP] No OriginalAlbum for '{filename}'.")
                    tags_album_missing += 1

            if not dry_run:
                if file_restored:
                    if verbose:
                        print(f"  [VERBOSE] Tags AFTER restore:")
                        if restore_title  and orig_title:
                            print(f"            → Title:  '{orig_title}'")
                        if restore_artist and orig_artist:
                            print(f"            → Artist: '{orig_artist}'")
                        if restore_album  and orig_album:
                            print(f"            → Album:  '{orig_album}'")
                    _apply_cleanup(tags, filepath, cleanup_options)
                    print(f"  [OK] Tags restored.")
                    restored += 1
                else:
                    print(f"  [SKIP] Nothing to restore for '{filename}'.")
                    skipped += 1

        except Exception as e:
            print(f"  [ERROR] Failed to restore '{filename}': {e}")
            errors += 1

    duration = time.time() - start_time
    print(f"\n{'=' * 60}")
    print(f"  SUMMARY")
    print(f"{'=' * 60}")
    print(f"  Run date:                {time.strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Directory:               '{directory}'")
    print(f"  Restored Album:          {restore_album}")
    print(f"  Restored Title:          {restore_title}")
    print(f"  Restored Artist:         {restore_artist}")
    print(f"  Duration:                {duration:.1f}s")
    print(f"{'─' * 60}")
    print(f"  FILES")
    print(f"{'─' * 60}")
    print(f"  Total found:             {total}")
    print(f"  Restored:                {restored}")
    print(f"  Skipped:                 {skipped}")
    print(f"  Errors:                  {errors}")
    print(f"{'─' * 60}")
    print(f"  TAGGING")
    print(f"{'─' * 60}")
    print(f"  Title restored:          {tags_title_restored}")
    print(f"  Artist restored:         {tags_artist_restored}")
    print(f"  Album restored:          {tags_album_restored}")
    print(f"  Title missing:           {tags_title_missing}")
    print(f"  Artist missing:          {tags_artist_missing}")
    print(f"  Album missing:           {tags_album_missing}")
    print(f"{'─' * 60}")
    if errors > 0:
        print(f"  Status:               ⚠️  Completed with errors")
    elif restored == 0:
        print(f"  Status:               ℹ️  Nothing to restore")
    else:
        print(f"  Status:               ✅ Completed successfully")
    print(f"{'=' * 60}")


