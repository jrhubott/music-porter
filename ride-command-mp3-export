#!/usr/bin/env python3
"""
⚠️  DEPRECATION NOTICE ⚠️

This script is a backward compatibility wrapper for the new unified
apple-to-ride-command tool. It will be removed in a future version.

Please migrate to using:
  ./apple-to-ride-command

See APPLE-TO-RIDE-COMMAND-GUIDE.md for full documentation.
"""

import sys
import os
import subprocess
from pathlib import Path

# Print deprecation warning
print("╔════════════════════════════════════════════════════════════════╗")
print("║                    DEPRECATION WARNING                         ║")
print("╚════════════════════════════════════════════════════════════════╝")
print()
print("  The 'ride-command-mp3-export' script has been replaced by:")
print("    → apple-to-ride-command")
print()
print("  This wrapper will be removed in a future version.")
print("  Please update your scripts and workflows.")
print()
print("  Migration guide: APPLE-TO-RIDE-COMMAND-GUIDE.md")
print()
print("  Continuing in 3 seconds...")
print()

import time
time.sleep(3)

# Get the directory where this script is located
script_dir = Path(__file__).parent.absolute()
new_cmd = script_dir / "apple-to-ride-command"

# Parse arguments and map to new command
args = sys.argv[1:]

# Build new command
cmd = [str(new_cmd)]

# Parse arguments
input_dir = None
output_dir = None
new_album = None
new_artist = None
restore_all = False
restore_album = False
restore_title = False
restore_artist = False
reset_tags = False
force = False
dry_run = False
verbose = False
keep_id3v1 = False
keep_id3v24 = False
keep_duplicates = False

i = 0
while i < len(args):
    arg = args[i]

    if arg in ['--help', '-h']:
        subprocess.run([str(new_cmd), '--help'])
        sys.exit(0)

    elif arg == '--dry-run':
        dry_run = True

    elif arg in ['--verbose', '-v']:
        verbose = True

    elif arg == '--output':
        i += 1
        output_dir = args[i] if i < len(args) else None

    elif arg == '--new-album':
        i += 1
        new_album = args[i] if i < len(args) else None

    elif arg == '--new-artist':
        i += 1
        new_artist = args[i] if i < len(args) else None

    elif arg == '--restore-all':
        restore_all = True

    elif arg == '--restore-album':
        restore_album = True

    elif arg == '--restore-title':
        restore_title = True

    elif arg == '--restore-artist':
        restore_artist = True

    elif arg == '--reset-tags-from-input':
        reset_tags = True

    elif arg == '--force':
        force = True

    elif arg == '--keep-id3v1':
        keep_id3v1 = True

    elif arg == '--keep-id3v24':
        keep_id3v24 = True

    elif arg == '--keep-duplicates':
        keep_duplicates = True

    elif not arg.startswith('-'):
        # Positional argument (input directory)
        if input_dir is None:
            input_dir = arg

    i += 1

# Add global flags
if dry_run:
    cmd.append('--dry-run')

if verbose:
    cmd.append('--verbose')

# Determine which subcommand to use
if reset_tags:
    # Reset tags from source
    cmd.append('reset')
    if input_dir:
        cmd.append(input_dir)
    if output_dir:
        cmd.append(output_dir)
    else:
        print("ERROR: --reset-tags-from-input requires --output directory")
        sys.exit(1)

elif restore_all or restore_album or restore_title or restore_artist:
    # Restore original tags
    cmd.append('restore')
    target_dir = output_dir or input_dir or 'converted_mp3'
    cmd.append(target_dir)

    if restore_all:
        cmd.append('--all')
    else:
        if restore_album:
            cmd.append('--album')
        if restore_title:
            cmd.append('--title')
        if restore_artist:
            cmd.append('--artist')

elif new_album or new_artist:
    # Tag update mode - may involve conversion first
    if input_dir and os.path.isdir(input_dir):
        # Check if input has M4A files
        has_m4a = any(Path(input_dir).rglob("*.m4a"))

        if has_m4a:
            # Convert first
            cmd.append('convert')
            cmd.append(input_dir)
            if output_dir:
                cmd.extend(['--output', output_dir])
            if force:
                cmd.append('--force')

            # Execute conversion
            result = subprocess.run(cmd)
            if result.returncode != 0:
                sys.exit(result.returncode)

            # Now update tags
            cmd = [str(new_cmd)]
            if dry_run:
                cmd.append('--dry-run')
            if verbose:
                cmd.append('--verbose')

    # Tag update
    cmd.append('tag')
    target_dir = output_dir or input_dir or 'converted_mp3'
    cmd.append(target_dir)

    if new_album:
        cmd.extend(['--album', new_album])
    if new_artist:
        cmd.extend(['--artist', new_artist])

else:
    # Conversion mode (default)
    cmd.append('convert')
    if input_dir:
        cmd.append(input_dir)
    else:
        cmd.append('.')

    if output_dir:
        cmd.extend(['--output', output_dir])

    if force:
        cmd.append('--force')

# Note: --keep-id3v1, --keep-id3v24, --keep-duplicates are not yet supported in new command
if keep_id3v1 or keep_id3v24 or keep_duplicates:
    print("\nWARNING: --keep-id3v1, --keep-id3v24, and --keep-duplicates flags")
    print("         are not yet implemented in apple-to-ride-command.")
    print("         These options will be ignored.")
    print()

# Execute the new command
os.execv(str(new_cmd), cmd)
