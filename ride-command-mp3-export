def parse_args():
    parser = argparse.ArgumentParser(
        description="ride-command-mp3-export: Convert M4A to MP3 and manage tags.",
        add_help=False
    )
    parser.add_argument("input_dir",          nargs="?", default=None)
    parser.add_argument("--output",           dest="output_dir", default=None)
    parser.add_argument("--force",            action="store_true")
    parser.add_argument("--new-album",        dest="new_album",  default=None)
    parser.add_argument("--new-artist",       dest="new_artist", default=None)
    parser.add_argument("--restore-all",      action="store_true")
    parser.add_argument("--restore-album",    action="store_true")
    parser.add_argument("--restore-title",    action="store_true")
    parser.add_argument("--restore-artist",   action="store_true")
    parser.add_argument("--reset-tags-from-input", dest="reset_tags_from_input", action="store_true")
    parser.add_argument("--keep-id3v1",       action="store_true")
    parser.add_argument("--keep-id3v24",      action="store_true")
    parser.add_argument("--keep-duplicates",  action="store_true")
    parser.add_argument("--dry-run",          action="store_true")
    parser.add_argument("--verbose", "-v",    action="store_true")
    parser.add_argument("-h", "--help",       action="store_true")
    return parser.parse_args()


def main():
    args = parse_args()

    if args.help:
        print_help()
        sys.exit(0)

    check_and_install_mutagen()

    dry_run = args.dry_run
    verbose = args.verbose
    force   = args.force

    if dry_run:
        print("[DRY-RUN] No files will be modified.\n")
    if verbose:
        print("[VERBOSE] Verbose mode enabled.\n")
    if force:
        print("[INFO] Force mode enabled — existing files will be overwritten.\n")

    cleanup_options = {
        "remove_id3v1":      not args.keep_id3v1,
        "use_id3v23":        not args.keep_id3v24,
        "remove_duplicates": not args.keep_duplicates
    }

    # ── Resolve output_dir early so all modes can use it ──────────
    output_dir = (
        os.path.abspath(args.output_dir)
        if args.output_dir
        else os.path.join(os.getcwd(), "converted_mp3")
    )

    # ── Reset tags from input mode ────────────────────────────────
    if args.reset_tags_from_input:
        input_dir = (
            os.path.abspath(args.input_dir)
            if args.input_dir
            else os.getcwd()
        )
        if not os.path.isdir(input_dir):
            print(f"[ERROR] Directory not found: '{input_dir}'")
            sys.exit(1)

        # ── Confirmation prompt (skipped for --dry-run) ───────────
        if not dry_run:
            print(f"\n⚠️  WARNING: --reset-tags-from-input will permanently overwrite all")
            print(f"   TXXX:Original* protection tags in '{output_dir}'")
            print(f"   with values read fresh from '{input_dir}'.")
            print(f"   This cannot be undone.\n")
            confirm = input(
                "   Type 'yes' to continue, anything else to cancel: "
            ).strip().lower()
            if confirm != "yes":
                print("\n[CANCELLED] Reset aborted. No files were modified.")
                sys.exit(0)
            print()

        rescan_from_source(
            input_dir       = input_dir,
            output_dir      = output_dir,
            cleanup_options = cleanup_options,
            dry_run         = dry_run,
            verbose         = verbose
        )
        return

    # ── Restore mode ──────────────────────────────────────────────
    restore_any = (
        args.restore_all or args.restore_album or
        args.restore_title or args.restore_artist
    )

    if restore_any:
        restore_tags(
            directory      = output_dir,
            restore_album  = args.restore_all or args.restore_album,
            restore_title  = args.restore_all or args.restore_title,
            restore_artist = args.restore_all or args.restore_artist,
            cleanup_options= cleanup_options,
            dry_run        = dry_run,
            verbose        = verbose
        )
        return

    # ── Tag update mode ───────────────────────────────────────────
    if args.new_album or args.new_artist:
        input_dir = os.path.abspath(args.input_dir) if args.input_dir else None

        if input_dir:
            if not os.path.isdir(input_dir):
                print(f"[ERROR] Directory not found: '{input_dir}'")
                sys.exit(1)
            check_ffmpeg()
            convert_m4a_to_mp3(
                input_dir       = input_dir,
                output_dir      = output_dir,
                cleanup_options = cleanup_options,
                dry_run         = dry_run,
                verbose         = verbose,
                force           = force
            )

        update_tags(
            directory      = output_dir,
            new_album      = args.new_album,
            new_artist     = args.new_artist,
            cleanup_options= cleanup_options,
            dry_run        = dry_run,
            verbose        = verbose
        )
        return

    # ── Conversion mode (default) ─────────────────────────────────
    input_dir = (
        os.path.abspath(args.input_dir)
        if args.input_dir
        else os.getcwd()
    )

    if not os.path.isdir(input_dir):
        print(f"[ERROR] Directory not found: '{input_dir}'")
        sys.exit(1)

    check_ffmpeg()

    convert_m4a_to_mp3(
        input_dir       = input_dir,
        output_dir      = output_dir,
        cleanup_options = cleanup_options,
        dry_run         = dry_run,
        verbose         = verbose,
        force           = force
    )


if __name__ == "__main__":
    main()