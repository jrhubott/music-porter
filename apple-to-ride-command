                               help='Restore artist tag')

    # ── reset ─────────────────────────────────────────────────────
    reset_parser = subparsers.add_parser('reset',
        help='Reset tags from source M4A files (⚠️ overwrites TXXX frames)')
    reset_parser.add_argument('input_dir', help='Input directory with M4A files')
    reset_parser.add_argument('output_dir', help='Output directory with MP3 files')

    # ── sync-usb ──────────────────────────────────────────────────
    sync_parser = subparsers.add_parser('sync-usb',
        parents=[usb_parent],
        help='Copy files to USB drive')
    sync_parser.add_argument('source_dir', nargs='?', default=DEFAULT_EXPORT_DIR,
                            help='Source directory to copy')

    # ── summary ───────────────────────────────────────────────────
    summary_parser = subparsers.add_parser('summary',
        help='Display export library statistics')
    summary_parser.add_argument('--export-dir', default=DEFAULT_EXPORT_DIR,
                               help=f'Export directory to analyze (default: {DEFAULT_EXPORT_DIR})')
    summary_parser.add_argument('--detailed', action='store_true',
                               help='Show detailed statistics and breakdowns')
    summary_parser.add_argument('--quick', action='store_true',
                               help='Show only aggregate statistics')

    return parser


