class DependencyChecker:
    """Checks and manages dependencies (mutagen, ffmpeg, gamdl, venv)."""

    def __init__(self, logger=None):
        self.logger = logger or Logger()
        self.venv_python = None
        self._detect_venv()

    def _detect_venv(self):
        """Detect virtual environment Python interpreter."""
        # Check if already in venv
        if os.environ.get('VIRTUAL_ENV'):
            self.venv_python = sys.executable
            self.logger.info(f"Using active venv: {os.environ['VIRTUAL_ENV']}")
            return

        # Check for .venv directory with OS-appropriate path
        if IS_WINDOWS:
            venv_path = Path('.venv/Scripts/python.exe')
        else:  # Unix (macOS, Linux)
            venv_path = Path('.venv/bin/python')

        if venv_path.exists():
            self.venv_python = str(venv_path.absolute())
            self.logger.info(f"Found venv at: {venv_path}")
        else:
            self.logger.warn("No virtual environment detected")
            self.venv_python = sys.executable

    def check_python_packages(self):
        """Check if Python packages are installed, install from requirements.txt if needed."""
        # Check if mutagen is available
        try:
            import mutagen
            self.logger.info(f"mutagen {mutagen.version_string} already installed")
            mutagen_installed = True
        except ImportError:
            mutagen_installed = False

        # Check if gamdl is available
        try:
            result = subprocess.run(
                [self.venv_python, "-m", "gamdl", "--version"],
                capture_output=True,
                check=True
            )
            self.logger.info("gamdl is already installed")
            gamdl_installed = True
        except (subprocess.CalledProcessError, FileNotFoundError):
            gamdl_installed = False

        # Check if ffmpeg-python is available
        try:
            import ffmpeg
            self.logger.info("ffmpeg-python is already installed")
            ffmpeg_python_installed = True
        except ImportError:
            ffmpeg_python_installed = False

        # If any packages are missing, try to install from requirements.txt
        if not mutagen_installed or not gamdl_installed or not ffmpeg_python_installed:
            requirements_path = Path("requirements.txt")
            if requirements_path.exists():
                self.logger.info("Python packages missing. Installing from requirements.txt...")
                try:
                    subprocess.check_call([
                        self.venv_python, "-m", "pip", "install", "-r", "requirements.txt"
                    ])
                    self.logger.ok("Python packages installed successfully from requirements.txt")
                    return True
                except subprocess.CalledProcessError as e:
                    self.logger.error(f"Failed to install from requirements.txt: {e}")
                    self._show_package_install_help()
                    return False
            else:
                self.logger.error("requirements.txt not found")
                self._show_package_install_help()
                return False

        return True

    def check_ffmpeg(self):
        """Check if ffmpeg is available."""
        try:
            subprocess.run(
                ["ffmpeg", "-version"],
                capture_output=True,
                check=True
            )
            self.logger.info("ffmpeg is available")
            return True
        except (subprocess.CalledProcessError, FileNotFoundError):
            self.logger.error("ffmpeg is not installed or not in PATH")
            self._show_ffmpeg_install_help()
            return False

    def _show_ffmpeg_install_help(self):
        """Show OS-specific ffmpeg installation instructions."""
        self.logger.error("\n=== FFmpeg Installation Required ===")

        if IS_MACOS:
            self.logger.error("Install via Homebrew:")
            self.logger.error("  brew install ffmpeg")
        elif IS_LINUX:
            self.logger.error("Install via package manager:")
            self.logger.error("  Ubuntu/Debian:  sudo apt-get install ffmpeg")
            self.logger.error("  Fedora/RHEL:    sudo dnf install ffmpeg")
            self.logger.error("  Arch:           sudo pacman -S ffmpeg")
        elif IS_WINDOWS:
            self.logger.error("Install options:")
            self.logger.error("  1. Chocolatey:  choco install ffmpeg")
            self.logger.error("  2. Download from: https://ffmpeg.org/download.html")
            self.logger.error("     Extract and add to PATH")

        self.logger.error("\nFFmpeg is a system dependency and cannot be auto-installed.")
        self.logger.error("Please install it manually and restart the tool.")

    def _show_package_install_help(self):
        """Show OS-specific Python package installation instructions."""
        self.logger.error("\n=== Python Package Installation Required ===")

        if IS_WINDOWS:
            self.logger.error("Activate virtual environment:")
            self.logger.error("  .venv\\Scripts\\activate")
            self.logger.error("Then install packages:")
            self.logger.error("  pip install -r requirements.txt")
        else:  # Unix (macOS, Linux)
            self.logger.error("Activate virtual environment and install:")
            self.logger.error("  source .venv/bin/activate")
            self.logger.error("  pip install -r requirements.txt")

    def check_gamdl(self):
        """Check if gamdl is available."""
        try:
            subprocess.run(
                [self.venv_python, "-m", "gamdl", "--help"],
                capture_output=True,
                check=True
            )
            self.logger.info("gamdl is available")
            return True
        except (subprocess.CalledProcessError, FileNotFoundError):
            return False

    def check_all(self, require_ffmpeg=True, require_gamdl=True):
        """Check all dependencies."""
        all_ok = True

        # Check and install Python packages from requirements.txt
        if not self.check_python_packages():
            all_ok = False

        if require_ffmpeg and not self.check_ffmpeg():
            all_ok = False

        # Verify gamdl is available after installation
        if require_gamdl and not self.check_gamdl():
            self.logger.error("gamdl is not available after installation")
            self._show_package_install_help()
            all_ok = False

        return all_ok


