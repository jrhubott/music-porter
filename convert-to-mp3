#!/usr/bin/env python3

import os
import sys
import subprocess
import argparse
import json

def print_help():
    help_text = """
╔══════════════════════════════════════════════════════════════════╗
║                    M4A to MP3 Converter                          ║
╚══════════════════════════════════════════════════════════════════╝

USAGE:
    ./convert_m4a_to_mp3.py [input_dir] [options]

ARGUMENTS:
    input_dir               Directory to scan for .m4a files
                            (default: current directory)

OPTIONS:
    --output "path"         Directory to save converted MP3 files
                            (default: ./converted_mp3)

    --album "Album Name"    Override the album tag in all output MP3s
                            The original album tag is saved and can
                            be restored later with --restore

    --restore               Restore original album tags in all MP3s
                            that were previously overridden

    -h, --help              Show this help message

OUTPUT:
    All converted MP3s are saved to ./converted_mp3/ by default
    Files are named: Artist - Title.mp3
    Original tags are saved to: <output_dir>/.original_tags/

EXAMPLES:
    # Convert all M4A files in current directory
    ./convert_m4a_to_mp3.py

    # Convert all M4A files in a specific directory
    ./convert_m4a_to_mp3.py /Users/jason/Music

    # Convert to a specific output directory
    ./convert_m4a_to_mp3.py /Users/jason/Music --output /Users/jason/MP3s

    # Convert and override the album tag
    ./convert_m4a_to_mp3.py /Users/jason/Music --album "My Playlist"

    # Convert with both output directory and album override
    ./convert_m4a_to_mp3.py /Users/jason/Music --output /Users/jason/MP3s --album "My Playlist"

    # Restore original album tags after an override
    ./convert_m4a_to_mp3.py --restore

    # Restore from a specific output directory
    ./convert_m4a_to_mp3.py --output /Users/jason/MP3s --restore

NOTES:
    - Existing MP3s are skipped (delete them to reconvert)
    - macOS metadata files (._*) are automatically excluded
    - The output directory is excluded from scanning
    - If artist or title tags are missing, the original
      filename is used as a fallback
    - All other tags (track, date, genre, etc.) are always
      preserved from the source file

REQUIREMENTS:
    - ffmpeg  (brew install ffmpeg)
    - ffprobe (included with ffmpeg)
    - python3 (included with macOS)
"""
    print(help_text)

def restore_original_tags(output_dir):
    """Restore original album tags from sidecar JSON files"""
    sidecar_dir = os.path.join(output_dir, ".original_tags")

    if not os.path.isdir(sidecar_dir):
        print("No saved original tags found. Nothing to restore.")
        sys.exit(0)

    sidecar_files = [f for f in os.listdir(sidecar_dir) if f.endswith(".json")]

    if not sidecar_files:
        print("No saved original tags found. Nothing to restore.")
        sys.exit(0)

    total    = len(sidecar_files)
    restored = 0
    skipped  = 0
    errors   = 0

    print(f"Output directory: {output_dir}")
    print(f"Found {total} file(s) with saved original tags")
    print("----------------------------------------")

    for sidecar_file in sorted(sidecar_files):
        sidecar_path = os.path.join(sidecar_dir, sidecar_file)

        with open(sidecar_path, "r", encoding="utf-8") as f:
            data = json.load(f)

        mp3_file       = data.get("file")
        original_album = data.get("original_album", "")
        mp3_path       = os.path.join(output_dir, mp3_file)

        print(f"  {mp3_file}")

        if not os.path.isfile(mp3_path):
            print(f"  ! MP3 file not found, skipping")
            skipped += 1
            continue

        # Write original album tag back using ffmpeg
        tmp_path = mp3_path + ".tmp.mp3"
        result = subprocess.run(
            [
                "ffmpeg", "-i", mp3_path,
                "-codec:a", "copy",
                "-map_metadata", "0",
                "-id3v2_version", "3",
                "-metadata", f"album={original_album}",
                "-y", tmp_path
            ],
            capture_output=True,
            text=True
        )

        if result.returncode == 0:
            os.replace(tmp_path, mp3_path)
            os.remove(sidecar_path)
            print(f"  ✓ Restored album tag: '{original_album}'")
            restored += 1
        else:
            if os.path.isfile(tmp_path):
                os.remove(tmp_path)
            print(f"  ✗ Failed to restore: {result.stderr.strip()}")
            errors += 1

    # Remove sidecar directory if empty
    if not os.listdir(sidecar_dir):
        os.rmdir(sidecar_dir)

    print("----------------------------------------")
    print(f"Restored : {restored}")
    print(f"Skipped  : {skipped}")
    print(f"Errors   : {errors}")
    print(f"Total    : {total}")

def sanitize(name):
    """Remove invalid filename characters"""
    if not name:
        return ""
    invalid = '/\\:*?"<>|'
    for char in invalid:
        name = name.replace(char, "")
    return name.strip()

def get_metadata(filepath):
    """Extract all relevant tags from file metadata using ffprobe"""
    result = subprocess.run(
        [
            "ffprobe", "-v", "quiet",
            "-print_format", "json",
            "-show_format",
            filepath
        ],
        capture_output=True,
        text=True
    )

    try:
        data = json.loads(result.stdout)
        tags = data.get("format", {}).get("tags", {})

        def get_tag(key):
            return tags.get(key) or tags.get(key.upper()) or tags.get(key.lower()) or ""

        return {
            "artist"     : get_tag("artist"),
            "title"      : get_tag("title"),
            "album"      : get_tag("album"),
            "track"      : get_tag("track"),
            "date"       : get_tag("date"),
            "genre"      : get_tag("genre"),
            "albumartist": get_tag("album_artist") or get_tag("albumartist"),
        }
    except Exception:
        return {}

def save_original_tags(output_path, output_dir, original_album):
    """Save original album tag to a sidecar JSON file"""
    sidecar_dir = os.path.join(output_dir, ".original_tags")
    os.makedirs(sidecar_dir, exist_ok=True)

    sidecar_file = os.path.join(sidecar_dir, os.path.basename(output_path) + ".json")

    data = {
        "file"          : os.path.basename(output_path),
        "original_album": original_album
    }

    with open(sidecar_file, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

def main():
    parser = argparse.ArgumentParser(description="Convert M4A files to MP3", add_help=False)
    parser.add_argument("input_dir",  nargs="?",         default=".",               help="Input directory to scan")
    parser.add_argument("--output",   metavar="DIR",      default=None,              help="Output directory for MP3 files")
    parser.add_argument("--album",    metavar="NAME",                                help="Override album tag in output MP3 files")
    parser.add_argument("--restore",  action="store_true",                           help="Restore original album tags")
    parser.add_argument("-h", "--help", action="store_true",                         help="Show help message")
    args = parser.parse_args()

    # Resolve output directory - use --output if provided, otherwise default
    if args.output:
        output_dir = os.path.abspath(args.output)
    else:
        output_dir = os.path.join(os.getcwd(), "converted_mp3")

    # Show help
    if args.help:
        print_help()
        sys.exit(0)

    # Restore original tags
    if args.restore:
        restore_original_tags(output_dir)
        sys.exit(0)

    input_dir = os.path.abspath(args.input_dir)

    # Check if ffmpeg and ffprobe are available
    for cmd in ["ffmpeg", "ffprobe"]:
        result = subprocess.run(["which", cmd], capture_output=True)
        if result.returncode != 0:
            print(f"Error: {cmd} is not installed or not in PATH")
            sys.exit(1)

    # Check if input directory exists
    if not os.path.isdir(input_dir):
        print(f"Error: Directory '{input_dir}' not found")
        sys.exit(1)

    # Warn if input and output directories are the same
    if os.path.abspath(input_dir) == os.path.abspath(output_dir):
        print(f"Error: Input and output directories cannot be the same")
        sys.exit(1)

    # Create output directory if it doesn't exist
    os.makedirs(output_dir, exist_ok=True)

    print(f"Input directory : {input_dir}")
    print(f"Output directory: {output_dir}")
    if args.album:
        print(f"Album override  : {args.album}")
    print("----------------------------------------")

    # Find all m4a files
    all_files = []
    for root, dirs, files in os.walk(input_dir):
        if os.path.abspath(root).startswith(os.path.abspath(output_dir)):
            dirs[:] = []
            continue
        for f in sorted(files):
            if f.lower().endswith(".m4a") and not f.startswith("._"):
                all_files.append(os.path.join(root, f))

    total = len(all_files)

    if total == 0:
        print(f"No .m4a files found in '{input_dir}'")
        sys.exit(0)

    print(f"Found {total} .m4a file(s) to convert")
    print("----------------------------------------")

    count     = 0
    skipped   = 0
    errors    = 0
    converted = 0

    for filepath in all_files:
        count += 1
        print(f"[{count}/{total}] {filepath}")

        if not os.access(filepath, os.R_OK):
            print(f"  ! Skipping unreadable file: {filepath}")
            errors += 1
            continue

        metadata = get_metadata(filepath)
        artist   = sanitize(metadata.get("artist", ""))
        title    = sanitize(metadata.get("title", ""))
        album    = metadata.get("album", "")
        fallback = os.path.splitext(os.path.basename(filepath))[0]

        if not artist and not title:
            output_name = fallback
            print(f"  ! No metadata found, using filename: {output_name}")
        elif not artist:
            output_name = title
            print(f"  ! No artist found, using title only: {output_name}")
        elif not title:
            output_name = f"{artist} - {fallback}"
            print(f"  ! No title found, using artist and filename: {output_name}")
        else:
            output_name = f"{artist} - {title}"

        output_path = os.path.join(output_dir, f"{output_name}.mp3")

        if os.path.isfile(output_path):
            print(f"  - Skipped: {os.path.basename(output_path)} already exists")
            skipped += 1
            continue

        ffmpeg_cmd = [
            "ffmpeg", "-i", filepath,
            "-codec:a", "libmp3lame",
            "-qscale:a", "2",
            "-map_metadata", "0",
            "-id3v2_version", "3",
        ]

        if args.album:
            ffmpeg_cmd += ["-metadata", f"album={args.album}"]
            save_original_tags(output_path, output_dir, album)
            print(f"  ~ Album: '{album}' → '{args.album}' (original saved)")

        ffmpeg_cmd += ["-y", output_path]

        result = subprocess.run(ffmpeg_cmd, capture_output=True, text=True)

        if result.returncode == 0:
            print(f"  ✓ Saved: {os.path.basename(output_path)}")
            converted += 1
        else:
            print(f"  ✗ Failed: {filepath}")
            print(f"    {result.stderr.strip()}")
            errors += 1

    print("----------------------------------------")
    print(f"Converted : {converted}")
    print(f"Skipped   : {skipped}")
    print(f"Errors    : {errors}")
    print(f"Total     : {count}")
    if args.album:
        print(f"\nOriginal album tags saved to: {os.path.join(output_dir, '.original_tags')}")
        print(f"To restore, run: ./convert_m4a_to_mp3.py --output {output_dir} --restore")

if __name__ == "__main__":
    main()