class USBManager:
    """Manages USB drive detection and file copying."""

    def __init__(self, logger=None, excluded_volumes=None):
        self.logger = logger or Logger()
        self.excluded_volumes = excluded_volumes or EXCLUDED_USB_VOLUMES

    def find_usb_drives(self):
        """
        Find available USB drives in /Volumes/, excluding system volumes.
        Returns list of volume names.
        """
        volumes_path = Path('/Volumes')

        if not volumes_path.exists():
            self.logger.error("/Volumes directory not found (non-macOS system?)")
            return []

        all_volumes = [v.name for v in volumes_path.iterdir() if v.is_dir()]

        # Filter out excluded volumes
        volumes = [
            v for v in all_volumes
            if v not in self.excluded_volumes
        ]

        return volumes

    def select_usb_drive(self):
        """
        Interactively select a USB drive if multiple are available.
        Returns selected volume name or None.
        """
        volumes = self.find_usb_drives()

        if not volumes:
            self.logger.error("No external drives found")
            self.logger.error("Make sure your USB drive is connected and mounted")
            return None

        if len(volumes) == 1:
            self.logger.info(f"Using USB drive: {volumes[0]}")
            return volumes[0]

        # Multiple drives found - prompt user
        print("Multiple drives found:")
        for i, vol in enumerate(volumes, 1):
            print(f"  {i}. {vol}")

        try:
            selection = input("Select drive: ").strip()
            index = int(selection) - 1

            if 0 <= index < len(volumes):
                return volumes[index]
            else:
                self.logger.error("Invalid selection")
                return None
        except (ValueError, KeyboardInterrupt):
            self.logger.error("Invalid input")
            return None

    def sync_to_usb(self, source_dir, usb_dir=DEFAULT_USB_DIR, dry_run=False):
        """
        Copy files from source_dir to USB drive using rsync.
        Returns success boolean.
        """
        source_path = Path(source_dir)

        if not source_path.exists():
            self.logger.error(f"Source directory does not exist: {source_path}")
            return False

        # Select USB drive
        volume = self.select_usb_drive()
        if not volume:
            return False

        dest = Path('/Volumes') / volume / usb_dir

        self.logger.info(f"Copying {source_path} to {dest}")

        if dry_run:
            self.logger.dry_run(f"Would create directory: {dest}")
            self.logger.dry_run(f"Would rsync: {source_path}/ → {dest}/")
            return True

        # Create destination directory
        try:
            dest.mkdir(parents=True, exist_ok=True)
        except Exception as e:
            self.logger.error(f"Failed to create destination directory: {e}")
            return False

        # Run rsync
        cmd = [
            "rsync", "-av", "--progress",
            str(source_path) + "/",
            str(dest) + "/"
        ]

        try:
            self.logger.info(f"Running: {' '.join(cmd)}")
            result = subprocess.run(cmd, check=True)
            self.logger.ok("Copy complete")
            return True
        except subprocess.CalledProcessError as e:
            self.logger.error(f"rsync failed: {e}")
            return False


