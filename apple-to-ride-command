        if "download" in self.stats.stages_completed or "download" in self.stats.stages_failed:
            print(f"{'─' * 70}")
            print(f"  DOWNLOAD STAGE")
            print(f"{'─' * 70}")
            if "download" in self.stats.stages_completed and self.stats.download_stats:
