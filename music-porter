class InteractiveMenu:
    """Provides interactive menu for playlist selection and operations."""

    def __init__(self, logger=None, config=None, deps=None, workers=None,
                 output_profile=None, prompt_handler=None, display_handler=None):
        self.logger = logger or Logger()
        self.config = config or ConfigManager(logger=self.logger)
        self.deps = deps or DependencyChecker(self.logger)
        self.workers = workers
        self.output_profile = output_profile or OUTPUT_PROFILES[DEFAULT_OUTPUT_TYPE]
        self.prompt_handler = prompt_handler or CLIPromptHandler()
        self.display_handler = display_handler or CLIDisplayHandler(self.logger)

    def show(self, dry_run=False, verbose=False):
        """Display interactive menu and handle user selection."""
        if not self.config.playlists:
            self.logger.warn("No playlists configured in config.yaml")
            self.logger.info("Use --url to download from a direct URL")
            return False

        # Loop until user exits
        while True:
            # Display menu
            print("\n╔══════════════════════════════════════════════════════════════╗")
            print("║                       Music Porter                           ║")
            print("╚══════════════════════════════════════════════════════════════╝")
            print("\n  📝 Process playlist:")
            print()

            for i, playlist in enumerate(self.config.playlists, 1):
                print(f"     {i}. {playlist.name} ({playlist.key})")

            print()  # Blank line before separator
            print("   ────────────────────────────────────────────────────────────")
            print()  # Blank line after separator

            print("  📁  A. Process all playlists")
            print("  🔗  U. Enter URL to add a new playlist")
            print("  💾  C. Copy to USB only")
            print("  📊  S. Show library summary")
            print("  🖼️  R. Resize all cover art")
            print(f"  🔧  P. Change output profile (current: {self.output_profile.name})")
            print("  ❌  X. Exit (or press Enter)")

            # Get user selection
            try:
                selection = input("\nEnter selection (or press Enter to exit): ").strip()

                # Handle empty input as exit
                if selection == "":
                    print("Exiting...")
                    return False

                # Normalize to uppercase for case-insensitive comparison
                selection_upper = selection.upper()

                # Validate input: must be digit (1-N) or valid letter (A, U, C, S, X)
                valid_letters = ['A', 'U', 'C', 'S', 'R', 'P', 'X']

                is_valid_digit = selection.isdigit() and 1 <= int(selection) <= len(self.config.playlists)
                is_valid_letter = selection_upper in valid_letters

                if not (is_valid_digit or is_valid_letter):
                    self.logger.error(f"Invalid selection: {selection}")
                    self.logger.info(f"Enter a playlist number (1-{len(self.config.playlists)}) or option (A/U/C/S/X/Enter)")
                    continue  # Loop back to menu

                # Handle selection
                if selection_upper == 'X':
                    print("Exiting...")
                    return False

                elif selection_upper == 'C':
                    self._handle_usb_only(dry_run)
                    # Return to menu after USB copy

                elif selection_upper == 'U':
                    self._handle_url_entry(dry_run, verbose)
                    # Return to menu after URL entry

                elif selection_upper == 'A':
                    self._handle_all_playlists(dry_run, verbose)
                    # Return to menu after processing all playlists

                elif selection_upper == 'S':
                    self._handle_summary(dry_run)
                    # Return to menu after showing summary

                elif selection_upper == 'R':
                    self._handle_resize_cover_art(dry_run, verbose)
                    # Return to menu after resizing

                elif selection_upper == 'P':
                    self._handle_change_profile()
                    # Return to menu after profile change

                elif selection.isdigit():
                    # Must be valid digit at this point (validated earlier)
                    playlist_num = int(selection)
                    self._handle_playlist_selection(playlist_num - 1, dry_run, verbose)
                    # Return to menu after processing playlist

                else:
                    # This should never be reached due to earlier validation
                    self.logger.error(f"Invalid selection: {selection}")
                    continue  # Loop back to menu

            except KeyboardInterrupt:
                print("\n\nCancelled by user")
                return False

    def _handle_playlist_selection(self, index, dry_run, verbose):
        """Handle selection of a single playlist."""
        playlist = self.config.playlists[index]

        self.logger.info(f"Selected: {playlist.name}")

        # Check cookies before processing
        if not dry_run:
            if not self._check_and_refresh_cookies():
                self.logger.error("Cannot process playlist without valid cookies")
                input("\nPress Enter to return to menu...")
                return False

        # Run pipeline for this playlist
        orchestrator = PipelineOrchestrator(self.logger, self.deps, self.config, workers=self.workers,
                                            output_profile=self.output_profile,
                                            prompt_handler=self.prompt_handler,
                                            display_handler=self.display_handler)

        result = orchestrator.run_full_pipeline(
            playlist=str(index + 1),
            auto=False,
            copy_to_usb=False,
            dry_run=dry_run,
            verbose=verbose
        )
        render_pipeline_summary(result)

        # Ask about USB copy
        if result.success and not dry_run:
            self._ask_copy_to_usb(
                get_export_dir(self.output_profile.name, playlist.key),
                dry_run
            )

        return result.success

    def _handle_all_playlists(self, dry_run, verbose):
        """Handle 'All playlists' selection."""
        self.logger.info("Processing all playlists...")

        # Check cookies before batch processing
        if not dry_run:
            if not self._check_and_refresh_cookies():
                self.logger.error("Cannot process playlists without valid cookies")
                input("\nPress Enter to return to menu...")
                return False

        # Create aggregate statistics tracker
        aggregate_stats = AggregateStatistics()

        for i, playlist in enumerate(self.config.playlists):
            self.logger.info(f"\n{'=' * 70}")
            self.logger.info(f"Processing playlist {i+1}/{len(self.config.playlists)}: {playlist.name}")
            self.logger.info(f"{'=' * 70}")

            orchestrator = PipelineOrchestrator(self.logger, self.deps, self.config, workers=self.workers,
                                                output_profile=self.output_profile,
                                                prompt_handler=self.prompt_handler,
                                                display_handler=self.display_handler)
            result = orchestrator.run_full_pipeline(
                playlist=str(i + 1),
                auto=True,
                copy_to_usb=False,
                dry_run=dry_run,
                verbose=verbose
            )
            render_pipeline_summary(result)

            # Collect statistics from this run
            aggregate_stats.add_playlist_result(orchestrator.stats)

            if not result.success:
                self.logger.error(f"Failed to process {playlist.name}")

        # Print aggregate summary (only for multiple playlists)
        if len(self.config.playlists) > 1:
            aggregate_stats.end_time = time.time()
            render_aggregate_summary(aggregate_stats.to_result())

        # Ask about USB copy after summary
        if not dry_run:
            self._ask_copy_to_usb(get_export_dir(self.output_profile.name), dry_run)

        return aggregate_stats.failed_playlists == 0

    def _handle_url_entry(self, dry_run, verbose):
        """Handle 'Enter URL' selection."""
        try:
            url = input("Enter Apple Music playlist URL: ").strip()

            if not url:
                self.logger.error("No URL provided")
                return False

            # Check cookies before processing
            if not dry_run:
                if not self._check_and_refresh_cookies():
                    self.logger.error("Cannot process URL without valid cookies")
                    input("\nPress Enter to return to menu...")
                    return False

            # Run pipeline for this URL
            orchestrator = PipelineOrchestrator(self.logger, self.deps, self.config, workers=self.workers,
                                                output_profile=self.output_profile,
                                                prompt_handler=self.prompt_handler,
                                                display_handler=self.display_handler)
            result = orchestrator.run_full_pipeline(
                url=url,
                auto=False,
                copy_to_usb=False,
                dry_run=dry_run,
                verbose=verbose
            )
            render_pipeline_summary(result)

            # Ask about USB copy
            if result.success and not dry_run:
                self._ask_copy_to_usb(
                    get_export_dir(self.output_profile.name, orchestrator.stats.playlist_key),
                    dry_run
                )

            return result.success

        except KeyboardInterrupt:
            print("\n\nCancelled by user")
            return False

    def _handle_usb_only(self, dry_run):
        """Handle 'Copy to USB only' selection."""
        self.logger.info("Copying existing files to USB...")

        usb_manager = USBManager(self.logger, prompt_handler=self.prompt_handler,
                                 display_handler=self.display_handler)
        usb_result = usb_manager.sync_to_usb(
            get_export_dir(self.output_profile.name),
            usb_dir=DEFAULT_USB_DIR,
            dry_run=dry_run
        )
        render_usb_sync_summary(usb_result)
        return usb_result.success

    def _handle_summary(self, dry_run):
        """Handle 'Show library summary' selection."""
        self.logger.info("Displaying library summary...")

        summary_manager = SummaryManager(self.logger)
        summary_result = summary_manager.generate_summary(
            export_dir=get_export_dir(self.output_profile.name),
            detailed=False,
            quick=False,
            dry_run=dry_run,
            music_dir=DEFAULT_MUSIC_DIR,
            export_profile=self.output_profile.name,
        )
        render_library_summary(summary_result, mode=summary_result.mode)

        # Pause for user to review before returning to menu
        if summary_result.success:
            try:
                input("\nPress Enter to continue...")
            except KeyboardInterrupt:
                print()
                pass

        return summary_result.success

    def _handle_resize_cover_art(self, dry_run, verbose):
        """Handle 'Resize all cover art' selection."""
        # Default from profile (fall back to 100 if profile says 0 or -1)
        profile_size = self.output_profile.artwork_size
        default_size = profile_size if profile_size > 0 else 100

        try:
            raw = input(f"Max dimension in pixels [{default_size}] (0=keep original, -1=strip artwork): ").strip()
            if raw == "":
                max_size = default_size
            else:
                try:
                    max_size = int(raw)
                    if max_size < -1:
                        self.logger.error("Value must be -1, 0, or a positive integer")
                        return False
                except ValueError:
                    self.logger.error(f"Invalid value: '{raw}' — must be a number")
                    return False
        except KeyboardInterrupt:
            print("\n\nCancelled by user")
            return False

        # Handle special values
        if max_size == 0:
            self.logger.info("Keeping original artwork — nothing to do")
            return True

        dirs = [get_export_dir(self.output_profile.name, p.key) for p in self.config.playlists]
        existing = [d for d in dirs if Path(d).exists()]

        if not existing:
            self.logger.error("No export directories found for configured playlists")
            return False

        cam = CoverArtManager(self.logger, output_profile=self.output_profile,
                              display_handler=self.display_handler)
        all_success = True

        if max_size == -1:
            self.logger.info(f"Stripping cover art from {len(existing)} playlist(s)...")
            for d in existing:
                self.logger.info(f"\n{'─' * 60}")
                self.logger.info(f"  Stripping: {d}")
                self.logger.info(f"{'─' * 60}")
                strip_result = cam.strip(d, dry_run=dry_run, verbose=verbose)
                render_cover_art_summary(strip_result)
                if not strip_result.success:
                    all_success = False
        else:
            self.logger.info(f"Resizing cover art to max {max_size}px across {len(existing)} playlist(s)...")
            for d in existing:
                self.logger.info(f"\n{'─' * 60}")
                self.logger.info(f"  Resizing: {d}")
                self.logger.info(f"{'─' * 60}")
                resize_result = cam.resize(d, max_size, dry_run=dry_run, verbose=verbose)
                render_cover_art_summary(resize_result)
                if not resize_result.success:
                    all_success = False

        try:
            input("\nPress Enter to continue...")
        except KeyboardInterrupt:
            print()

        return all_success

    def _handle_change_profile(self):
        """Handle 'Change output profile' selection."""
        profiles = list(OUTPUT_PROFILES.items())
        print("\n  Available output profiles:")
        print()
        for i, (name, profile) in enumerate(profiles, 1):
            current = " (current)" if name == self.output_profile.name else ""
            print(f"     {i}. {name} — {profile.description}{current}")
        print()

        try:
            choice = input("Select profile number (or Enter to cancel): ").strip()
            if not choice:
                return

            if not choice.isdigit() or not (1 <= int(choice) <= len(profiles)):
                self.logger.error(f"Invalid selection: {choice}")
                return

            name, profile = profiles[int(choice) - 1]
            self.output_profile = profile
            self.config.update_setting('output_type', name)
            self.logger.info(f"Output profile changed to: {name} ({profile.description})")
            self.logger.info(f"Exports will go to: {get_export_dir(name)}/")
        except KeyboardInterrupt:
            print()

    def _check_and_refresh_cookies(self, cookie_path='cookies.txt'):
        """
        Check cookie validity and offer to refresh if invalid.
        Returns True if cookies are valid or successfully refreshed, False otherwise.
        """
        cookie_manager = CookieManager(cookie_path, self.logger,
                                       prompt_handler=self.prompt_handler)
        status = cookie_manager.validate()

        if status.valid:
            # Cookies are valid, no action needed
            return True

        # Cookies are invalid - show instructions and offer refresh
        self.logger.error(status.reason)
        cookie_manager.show_manual_instructions()

        try:
            response = input("Attempt automatic cookie refresh? [Y/n] ").strip().lower()
            if response in ['', 'y', 'yes']:
                # User wants to try auto-refresh
                if cookie_manager.auto_refresh():
                    # Refresh succeeded, re-validate
                    status = cookie_manager.validate()
                    if status.valid:
                        self.logger.ok("Cookie refresh successful!")
                        return True
                    else:
                        self.logger.error("Cookies still invalid after refresh")
                        return False
                else:
                    self.logger.error("Automatic cookie refresh failed")
                    return False
            else:
                # User declined auto-refresh
                self.logger.info("Skipping cookie refresh")
                return False
        except KeyboardInterrupt:
            print("\n\nCancelled by user")
            return False

    def _ask_copy_to_usb(self, source_dir, dry_run):
        """Ask user if they want to copy to USB."""
        try:
            response = input("\nCopy files to USB? [y/N] ").strip().lower()
            if response == 'y':
                usb_manager = USBManager(self.logger, prompt_handler=self.prompt_handler,
                                         display_handler=self.display_handler)
                usb_result = usb_manager.sync_to_usb(
                    source_dir,
                    usb_dir=DEFAULT_USB_DIR,
                    dry_run=dry_run
                )
                render_usb_sync_summary(usb_result)
        except KeyboardInterrupt:
            print()
            pass


