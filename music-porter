def _format_size_for_renderer(bytes_size: int) -> str:
    """Format bytes to human-readable size (shared by renderers)."""
    if bytes_size < 1024:
        return f"{bytes_size} B"
    elif bytes_size < 1024 * 1024:
        return f"{bytes_size / 1024:.1f} KB"
    elif bytes_size < 1024 * 1024 * 1024:
        return f"{bytes_size / (1024 * 1024):.1f} MB"
    else:
        return f"{bytes_size / (1024 * 1024 * 1024):.1f} GB"


def render_library_summary(r: LibrarySummaryResult, mode: str = "default") -> None:
    """Render library summary. mode: 'quick', 'default', or 'detailed'."""
    # Render music library stats first if available
    if r.music_library_stats is not None:
        ms = r.music_library_stats
        if ms.total_files > 0:
            print()
            print("╔" + "═" * 60 + "╗")
            print("║" + "LIBRARY STATS".center(60) + "║")
            print("╚" + "═" * 60 + "╝")
            print()
            print(f"  Directory:               '{DEFAULT_MUSIC_DIR}/'")
            print(f"  Total playlists:         {ms.total_playlists}")
            print(f"  Total M4A files:         {ms.total_files}")
            print(f"  Total library size:      {_format_size_for_renderer(ms.total_size_bytes)}")
            if ms.total_files > 0:
                pct = (ms.total_exported / ms.total_files) * 100
                print(f"  Exported:                {ms.total_exported}/{ms.total_files} ({pct:.0f}%)")
                if ms.total_unconverted > 0:
                    print(f"  Unconverted:             {ms.total_unconverted}")
                else:
                    print("  Unconverted:             0  ✅")
            print(f"  Scan duration:           {ms.scan_duration:.1f}s")
            print()

    if r.total_files == 0 and r.total_playlists == 0:
        # Empty library
        print()
        print("╔" + "═" * 60 + "╗")
        print("║" + "PLAYLIST SUMMARY".center(60) + "║")
        print("╚" + "═" * 60 + "╝")
        print()
        print(f"  Directory:               '{r.export_dir}'")
        print("  Total playlists:         0")
        print("  Total MP3 files:         0")
        print()
        print("  ℹ️  Library is empty")
        print()
        print("  Suggested next steps:")
        print("    • Run: ./music-porter pipeline --auto")
        print("    • Or download a playlist: ./music-porter download --playlist 1")
        print()
        return

    if mode == "quick":
        _render_quick_summary(r)
    elif mode == "detailed":
        _render_default_summary(r)
        _render_detailed_extras(r)
    else:
        _render_default_summary(r)


