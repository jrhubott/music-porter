{
  "name": "@mporter/gui",
  "version": "1.0.0",
  "author": "Music Porter",
  "description": "Music Porter Sync - Electron desktop app",
  "type": "module",
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "vite --config src/renderer/vite.config.ts",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && vite build --config src/renderer/vite.config.ts",
    "start": "electron ./dist/main/index.js",
    "pack": "electron-builder"
  },
  "dependencies": {
    "@mporter/core": "*",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0"
  }
}
