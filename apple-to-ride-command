def resolve_quality_preset(args, logger):
    """
    Resolve quality preset from CLI args.
    Validates --preset custom + --quality combinations.
    Returns the resolved preset string.
    """
    quality_preset = args.preset
    if quality_preset == 'custom':
        if args.quality is None:
            logger.error("--preset custom requires --quality parameter (0-9)")
            sys.exit(1)
        if not (0 <= args.quality <= 9):
            logger.error(f"--quality must be between 0-9, got: {args.quality}")
            sys.exit(1)
        quality_preset = str(args.quality)
    elif args.quality is not None:
        logger.warn("--quality ignored unless --preset custom is specified")
    return quality_preset


def _create_quality_args_parser():
    """Create shared parent parser for quality-related arguments."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('--preset', default='lossless',
                        choices=['low', 'medium', 'high', 'lossless', 'custom'],
                        help='Quality preset (default: lossless)')
    parser.add_argument('--quality', type=int, metavar='0-9',
                        help='Custom VBR quality (0=best, 9=worst). Requires --preset custom')
    return parser


def _create_cookie_args_parser():
    """Create shared parent parser for cookie-related arguments."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('--cookies', default='cookies.txt',
                        help='Path to cookies.txt file (default: cookies.txt)')
    parser.add_argument('--auto-refresh-cookies', action='store_true',
                        help='Automatically refresh cookies if expired (requires selenium, opens browser)')
    parser.add_argument('--skip-cookie-validation', action='store_true',
                        help='Skip cookie validation (not recommended)')
    return parser


def _create_usb_args_parser():
    """Create shared parent parser for USB-related arguments."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('--usb-dir', default=DEFAULT_USB_DIR,
                        help=f'USB directory (default: {DEFAULT_USB_DIR})')
    return parser


def positive_int(value):
    """Argparse type for positive integers (1+)."""
    try:
        ivalue = int(value)
    except ValueError:
        raise argparse.ArgumentTypeError(f"'{value}' is not a valid integer")
    if ivalue < 1:
        raise argparse.ArgumentTypeError(f"'{value}' is not a positive integer (must be >= 1)")
    return ivalue


def create_parser():
    """Create the argument parser with subcommands."""
    parser = argparse.ArgumentParser(
        prog='apple-to-ride-command',
        description='''\033[1;36mApple Music to Ride Command MP3 Converter\033[0m

A comprehensive music playlist management and conversion tool that:
  \033[32m•\033[0m Downloads Apple Music playlists using gamdl
  \033[32m•\033[0m Converts M4A to MP3 with configurable quality presets
  \033[32m•\033[0m Preserves metadata with TXXX frame protection
  \033[32m•\033[0m Manages tags with update, restore, and reset operations
  \033[32m•\033[0m Syncs to USB drives with automatic detection
  \033[32m•\033[0m Validates and auto-refreshes Apple Music cookies
  \033[32m•\033[0m Provides interactive menu and pipeline orchestration
  \033[32m•\033[0m Supports dry-run mode for safe previews
  \033[32m•\033[0m Cross-platform: macOS, Linux, and Windows
''',
        epilog=f'''
Default Paths:
  \033[1mDownloads:\033[0m  \033[36m{DEFAULT_MUSIC_DIR}/\033[0m
  \033[1mExports:\033[0m    \033[36m{DEFAULT_EXPORT_DIR}/\033[0m
  \033[1mLogs:\033[0m       \033[36m{DEFAULT_LOG_DIR}/\033[0m
  \033[1mConfig:\033[0m     \033[36m{DEFAULT_PLAYLISTS_CONF}\033[0m
  \033[1mCookies:\033[0m    \033[36m{DEFAULT_COOKIES}\033[0m
  \033[1mUSB Target:\033[0m \033[36m{DEFAULT_USB_DIR}\033[0m

For command-specific help: \033[36mapple-to-ride-command <command> --help\033[0m
''',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )

    parser.add_argument('--version', action='version', version=f'%(prog)s {VERSION}')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='Enable verbose output')
    parser.add_argument('--dry-run', action='store_true',
                       help='Preview changes without modifying files')
    parser.add_argument('--workers', type=positive_int, default=DEFAULT_WORKERS,
                       metavar='N',
                       help=f'Parallel conversion workers (default: {DEFAULT_WORKERS})')

    subparsers = parser.add_subparsers(dest='command', help='Available commands')

    # Shared parent parsers
    quality_parent = _create_quality_args_parser()
    cookie_parent = _create_cookie_args_parser()
    usb_parent = _create_usb_args_parser()

    # ── pipeline (default) ────────────────────────────────────────
    pipeline_parser = subparsers.add_parser('pipeline',
        parents=[quality_parent, cookie_parent, usb_parent],
        help='Full download + convert + tag workflow (default)')
    pipeline_parser.add_argument('--playlist', help='Playlist name or number')
    pipeline_parser.add_argument('--url', help='Apple Music playlist URL')
    pipeline_parser.add_argument('--auto', action='store_true',
                                help='Process all playlists without prompting')
    pipeline_parser.add_argument('--copy-to-usb', action='store_true',
                                help='Copy to USB drive after processing')

    # ── download ──────────────────────────────────────────────────
    download_parser = subparsers.add_parser('download',
        parents=[cookie_parent],
        help='Download from Apple Music using gamdl')
    download_parser.add_argument('--playlist', help='Playlist name or number')
    download_parser.add_argument('--url', required=False, help='Apple Music playlist URL')
    download_parser.add_argument('--output', help='Output directory')

    # ── convert ───────────────────────────────────────────────────
    convert_parser = subparsers.add_parser('convert',
        parents=[quality_parent],
        help='Convert M4A → MP3 with tag preservation')
    convert_parser.add_argument('input_dir', help='Input directory with M4A files')
    convert_parser.add_argument('--output', help='Output directory')
    convert_parser.add_argument('--force', action='store_true',
                               help='Re-convert existing files')

    # ── tag ───────────────────────────────────────────────────────
    tag_parser = subparsers.add_parser('tag',
        help='Update tags on existing MP3s')
    tag_parser.add_argument('directory', help='Directory with MP3 files')
    tag_parser.add_argument('--album', help='New album name')
    tag_parser.add_argument('--artist', help='New artist name')

    # ── restore ───────────────────────────────────────────────────
    restore_parser = subparsers.add_parser('restore',
        help='Restore original tags from TXXX frames')
    restore_parser.add_argument('directory', help='Directory with MP3 files')
    restore_parser.add_argument('--all', action='store_true',
                               help='Restore all tags')
    restore_parser.add_argument('--album', action='store_true',
                               help='Restore album tag')
    restore_parser.add_argument('--title', action='store_true',
                               help='Restore title tag')
