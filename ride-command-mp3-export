def rescan_from_source(input_dir, output_dir, cleanup_options=None,
                        dry_run=False, verbose=False):
    """
    Recursively walk input_dir for .m4a files. For each one, read the
    original Title, Artist, and Album tags directly from the source,
    find the matching MP3 in output_dir, reset all three TXXX:Original*
    protection tags from the source values, rewrite TIT2/TPE1/TALB,
    refresh the title to 'Artist - Title' format, and save. [2]
    """
    from mutagen.mp4 import MP4
    from mutagen.id3 import ID3, TIT2, TPE1, TALB, TXXX, ID3NoHeaderError

    start_time = time.time()

    if cleanup_options is None:
        cleanup_options = {
            "remove_id3v1":      True,
            "use_id3v23":        True,
            "remove_duplicates": True
        }

    if not os.path.isdir(input_dir):
        print(f"[ERROR] Input directory not found: '{input_dir}'")
        return

    if not os.path.isdir(output_dir):
        print(f"[ERROR] Output directory not found: '{output_dir}'")
        return

    m4a_files = [
        os.path.join(root, f)
        for root, dirs, files in os.walk(input_dir)
        for f in files
        if f.lower().endswith('.m4a') and not f.startswith('._')
    ]

    if not m4a_files:
        print(f"[INFO] No .m4a files found in '{input_dir}'.")
        return

    total      = len(m4a_files)
    count      = 0
    updated    = 0
    skipped    = 0
    errors     = 0
    tags_reset = 0

    print(f"[INFO] Found {total} .m4a source file(s). Scanning...")
    if dry_run:
        print("[DRY-RUN] No files will be modified.\n")

    for input_path in m4a_files:
        count += 1
        display_name = os.path.relpath(input_path, input_dir)
        print(f"\n[{count}/{total}] Resetting tags from source: '{display_name}'")

        try:
            m4a = MP4(input_path)
            title  = str(m4a.tags.get('\xa9nam', ['Unknown Title'])[0])
            artist = str(m4a.tags.get('\xa9ART', ['Unknown Artist'])[0])
            album  = str(m4a.tags.get('\xa9alb', ['Unknown Album'])[0])

            safe_title   = "".join(c for c in title  if c not in r'\/:*?"<>|')
            safe_artist  = "".join(c for c in artist if c not in r'\/:*?"<>|')
            mp3_filename = f"{safe_artist} - {safe_title}.mp3"
            mp3_path     = os.path.join(output_dir, mp3_filename)

            if not os.path.isfile(mp3_path):
                print(f"  [SKIP] No matching MP3 found: '{mp3_filename}'")
                skipped += 1
                continue

            if verbose:
                print(f"  [VERBOSE] Source .m4a tags:")
                print(f"            → Title:  '{title}'")
                print(f"            → Artist: '{artist}'")
                print(f"            → Album:  '{album}'")
                print(f"  [VERBOSE] Matched MP3: '{mp3_path}'")

            if dry_run:
                print(f"  [DRY-RUN] Would reset MP3 tags from source:")
                print(f"            → TIT2 / OriginalTitle:  '{title}'")
                print(f"            → TPE1 / OriginalArtist: '{artist}'")
                print(f"            → TALB / OriginalAlbum:  '{album}'")
                print(f"            → Title would become:    '{artist} - {title}'")
                continue

            try:
                tags = ID3(mp3_path)
            except ID3NoHeaderError:
                tags = ID3()

            # ── Hard reset: remove existing Original* TXXX frames ──
            # This clears the hard gate so save_original_tag() can
            # write fresh values from the source .m4a [2]
            for key in list(tags.keys()):
                frame = tags[key]
                if isinstance(frame, TXXX) and frame.desc in {
                    "OriginalTitle", "OriginalArtist", "OriginalAlbum"
                }:
                    del tags[key]
                    tags_reset += 1

            # ── Write fresh base tags from source .m4a ────────────
            tags["TIT2"] = TIT2(encoding=3, text=title)
            tags["TPE1"] = TPE1(encoding=3, text=artist)
            tags["TALB"] = TALB(encoding=3, text=album)

            # ── Store fresh originals — gate is clear after reset ──
            save_original_tag(tags, "TXXX:OriginalTitle",  "OriginalTitle",
                              title,  "title")
            save_original_tag(tags, "TXXX:OriginalArtist", "OriginalArtist",
                              artist, "artist")
            save_original_tag(tags, "TXXX:OriginalAlbum",  "OriginalAlbum",
                              album,  "album")

            # ── Refresh Title to 'Artist - Title' format ──────────
            update_title_tag(tags, cleanup_options,
                             dry_run=dry_run, verbose=verbose)

            _apply_cleanup(tags, mp3_path, cleanup_options)

            if verbose:
                print(f"  [VERBOSE] Tags AFTER reset:")
                print(f"            → Title:          '{str(tags['TIT2'])}'")
                print(f"            → Artist:         '{artist}'")
                print(f"            → Album:          '{album}'")
                print(f"            → OriginalTitle:  '{title}'")
                print(f"            → OriginalArtist: '{artist}'")
                print(f"            → OriginalAlbum:  '{album}'")

            print(f"  [OK] Tags reset from source → '{mp3_filename}'")
            updated += 1

        except Exception as e:
            print(f"  [ERROR] Failed to reset tags for '{display_name}': {e}")
            errors += 1

    duration = time.time() - start_time
    print(f"\n{'=' * 60}")
    print(f"  SUMMARY")
    print(f"{'=' * 60}")
    print(f"  Run date:                {time.strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Input directory:         '{input_dir}'")
    print(f"  Output directory:        '{output_dir}'")
    print(f"  Duration:                {duration:.1f}s")
    print(f"{'─' * 60}")
    print(f"  FILES")
    print(f"{'─' * 60}")
    print(f"  Total .m4a found:        {total}")
    print(f"  MP3s updated:            {updated}")
    print(f"  Skipped (no MP3 match):  {skipped}")
    print(f"  Errors:                  {errors}")
    print(f"{'─' * 60}")
    print(f"  TAGGING")
    print(f"{'─' * 60}")
    print(f"  Original tags reset:     {tags_reset}")
    print(f"  Original tags rewritten: {updated * 3}")
    print(f"{'─' * 60}")
    if errors > 0:
        print(f"  Status:               ⚠️  Completed with errors")
    elif updated == 0:
        print(f"  Status:               ℹ️  No MP3s updated")
    else:
        print(f"  Status:               ✅ Completed successfully")
    print(f"{'=' * 60}")


