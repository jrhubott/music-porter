#!/usr/bin/env bash
#
# ⚠️  DEPRECATION NOTICE ⚠️
#
# This script is a backward compatibility wrapper for the new unified
# apple-to-ride-command tool. It will be removed in a future version.
#
# Please migrate to using:
#   ./apple-to-ride-command
#
# See APPLE-TO-RIDE-COMMAND-GUIDE.md for full documentation.
#

set -eo pipefail

echo "╔════════════════════════════════════════════════════════════════╗"
echo "║                    DEPRECATION WARNING                         ║"
echo "╚════════════════════════════════════════════════════════════════╝"
echo ""
echo "  The 'do-it-all' script has been replaced by:"
echo "    → apple-to-ride-command"
echo ""
echo "  This wrapper will be removed in a future version."
echo "  Please update your scripts and workflows."
echo ""
echo "  Migration guide: APPLE-TO-RIDE-COMMAND-GUIDE.md"
echo ""
echo "  Continuing in 3 seconds..."
echo ""
sleep 3

# Get the directory where this script is located
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
new_cmd="$script_dir/apple-to-ride-command"

# Parse arguments and map to new command
args=()
auto_mode=0
url_arg=""
playlist_arg=""
copy_to_usb=0
usb_dir=""
dry_run=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --auto)
            auto_mode=1
            ;;
        --dry-run)
            dry_run=1
            ;;
        --copy-to-usb)
            copy_to_usb=1
            ;;
        --url)
            url_arg="$2"
            shift
            ;;
        --playlist)
            playlist_arg="$2"
            shift
            ;;
        --usb-dir)
            usb_dir="$2"
            shift
            ;;
        --help)
            exec "$new_cmd" --help
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
    shift
done

# Build new command
cmd=("$new_cmd")

# Add global flags
if [[ $dry_run -eq 1 ]]; then
    cmd+=(--dry-run)
fi

# Determine command
if [[ $copy_to_usb -eq 1 ]] && [[ -z "$url_arg" ]] && [[ -z "$playlist_arg" ]] && [[ $auto_mode -eq 0 ]]; then
    # Copy to USB only
    cmd+=(sync-usb)
    if [[ -n "$usb_dir" ]]; then
        cmd+=(--usb-dir "$usb_dir")
    fi
else
    # Pipeline command
    if [[ $auto_mode -eq 1 ]] || [[ -n "$url_arg" ]] || [[ -n "$playlist_arg" ]]; then
        cmd+=(pipeline)

        if [[ $auto_mode -eq 1 ]]; then
            cmd+=(--auto)
        fi

        if [[ -n "$url_arg" ]]; then
            cmd+=(--url "$url_arg")
        fi

        if [[ -n "$playlist_arg" ]]; then
            cmd+=(--playlist "$playlist_arg")
        fi

        if [[ $copy_to_usb -eq 1 ]]; then
            cmd+=(--copy-to-usb)
        fi

        if [[ -n "$usb_dir" ]]; then
            cmd+=(--usb-dir "$usb_dir")
        fi

        # Execute pipeline command
        exec "${cmd[@]}"
    else
        # No arguments - show interactive menu
        exec "$new_cmd"
    fi
fi

exec "${cmd[@]}"
