def _render_playlist_table(playlists: list) -> None:
    """Print formatted table of playlists."""
    if not playlists:
        print("  (no playlists found)")
        return

    # Header
    print(f"  {'Playlist':<25} {'Files':>6}  {'Art/Mod':>9}  {'Size':>10}  {'Updated':<10}")
    print("  " + "─" * 62)

    # Sort by name
    sorted_playlists = sorted(playlists, key=lambda p: p.name)

    today = datetime.now().date()
    for playlist in sorted_playlists:
        name = playlist.name[:24]
        files = str(playlist.file_count)
        art = f"{playlist.files_with_cover_art}/{playlist.files_with_resized_cover_art}"

        if playlist.files_with_resized_cover_art > 0 and playlist.files_with_cover_art != playlist.files_with_resized_cover_art:
            art = f"⚠️{art}"

        size = _format_size_for_renderer(playlist.total_size_bytes)

        icon, _ = _get_freshness(playlist.last_modified, today)
        if playlist.last_modified:
            date_str = playlist.last_modified.strftime("%b %d")
        else:
            date_str = "N/A"
        updated = f"{icon} {date_str}" if icon else f"  {date_str}"

        print(f"  {name:<25} {files:>6}  {art:>9}  {size:>10}  {updated:<10}")

    print("  " + "─" * 62)


