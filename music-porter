    print("  PIPELINE SUMMARY")
    print(f"{'=' * 70}")
    print(f"  Run date:                {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print(f"  Playlist:                {r.playlist_name or '—'} ({r.playlist_key or '—'})")
    print(f"  Duration:                {r.duration:.1f}s")

    # Download stage
    if "download" in r.stages_completed or "download" in r.stages_failed or "download" in r.stages_skipped:
        print(f"{'─' * 70}")
        print("  DOWNLOAD STAGE")
        print(f"{'─' * 70}")
        if "download" in r.stages_completed and r.download_result:
            d = r.download_result
