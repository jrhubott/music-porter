def resolve_quality_preset(args, logger, output_profile=None):
    """
    Resolve quality preset from CLI args, falling back to profile default.
    Validates --preset custom + --quality combinations.
    Returns the resolved preset string, or None if no explicit CLI override.
    """
    quality_preset = args.preset
    if quality_preset is None:
        # No explicit CLI flag — fall back to profile default
        if output_profile:
            return output_profile.quality_preset
        return DEFAULT_QUALITY_PRESET
    if quality_preset == 'custom':
        if args.quality is None:
            logger.error("--preset custom requires --quality parameter (0-9)")
            sys.exit(1)
        if not (0 <= args.quality <= 9):
            logger.error(f"--quality must be between 0-9, got: {args.quality}")
            sys.exit(1)
        quality_preset = str(args.quality)
    elif args.quality is not None:
        logger.warn("--quality ignored unless --preset custom is specified")
    return quality_preset


def resolve_config_settings(args, config):
    """
    Resolve output_type, usb_dir, workers, dir_structure, and filename_format
    from CLI > config.yaml > constant/profile default.
    Returns (output_type, usb_dir, workers, dir_structure, filename_format) tuple.
    """
    # output_type: CLI > config > DEFAULT_OUTPUT_TYPE
    output_type = args.output_type
    if output_type is None:
        output_type = config.get_setting('output_type', DEFAULT_OUTPUT_TYPE)

    # usb_dir: CLI > config > DEFAULT_USB_DIR
    usb_dir = getattr(args, 'usb_dir', None)
    if usb_dir is None:
        usb_dir = config.get_setting('usb_dir', DEFAULT_USB_DIR)

    # workers: CLI > config > DEFAULT_WORKERS
    workers = args.workers
    if workers is None:
        workers = config.get_setting('workers', DEFAULT_WORKERS)

    # dir_structure: CLI > config > None (profile default used later)
    dir_structure = getattr(args, 'dir_structure', None)
    if dir_structure is None:
        dir_structure = config.get_setting('dir_structure', None)

    # filename_format: CLI > config > None (profile default used later)
    filename_format = getattr(args, 'filename_format', None)
    if filename_format is None:
        filename_format = config.get_setting('filename_format', None)

    return output_type, usb_dir, workers, dir_structure, filename_format


def _create_quality_args_parser():
    """Create shared parent parser for quality-related arguments."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('--preset', default=None,
                        choices=['low', 'medium', 'high', 'lossless', 'custom'],
                        help='Quality preset (default: from output profile)')
    parser.add_argument('--quality', type=int, metavar='0-9',
                        help='Custom VBR quality (0=best, 9=worst). Requires --preset custom')
    return parser


def _create_cookie_args_parser():
    """Create shared parent parser for cookie-related arguments."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('--cookies', default=DEFAULT_COOKIES,
