class CLIPromptHandler:
    """CLI implementation of UserPromptHandler using input().

    confirm() formats as "message [Y/n] " or "message [y/N] " based
    on default. confirm_destructive() requires typing "yes".
    select_from_list() prints numbered options and reads an integer.
    """

    def confirm(self, message: str, default: bool = True) -> bool:
        hint = "[Y/n]" if default else "[y/N]"
        try:
            response = input(f"{message} {hint} ").strip().lower()
            if response == '':
                return default
            return response in ('y', 'yes')
        except (KeyboardInterrupt, EOFError):
            print()
            return default

    def confirm_destructive(self, message: str) -> bool:
        try:
            response = input(
                f"{message}\n   Type 'yes' to continue, anything else to cancel: "
            ).strip().lower()
            return response == 'yes'
        except (KeyboardInterrupt, EOFError):
            print()
            return False

    def select_from_list(self, prompt: str, options: list[str],
                         allow_cancel: bool = True) -> int | None:
        for i, option in enumerate(options, 1):
            print(f"  {i}. {option}")
        try:
            selection = input(f"{prompt} ").strip()
            index = int(selection) - 1
            if 0 <= index < len(options):
                return index
            return None
        except (ValueError, KeyboardInterrupt, EOFError):
            return None

    def get_text_input(self, prompt: str,
                       default: str | None = None) -> str | None:
        try:
            if default:
                response = input(f"{prompt} [{default}]: ").strip()
                return response if response else default
            else:
                response = input(f"{prompt}: ").strip()
                return response if response else None
        except (KeyboardInterrupt, EOFError):
            print()
            return default

    def wait_for_continue(self, message: str,
                          timeout: float | None = None) -> None:
        try:
            input(message)
        except (KeyboardInterrupt, EOFError):
            print()



class CLIDisplayHandler:
    """CLI implementation of DisplayHandler using print() and ProgressBar.

    show_progress() manages a tqdm ProgressBar internally.
    show_status() prints with optional ANSI color based on level.
    show_banner() prints the startup banner.
    """

    def __init__(self, logger: Logger | None = None):
        self._logger = logger
        self._bar: ProgressBar | None = None
        self._bar_total: int = 0
        self._bar_desc: str = ""
        self._lock = threading.Lock()

    def show_progress(self, current: int, total: int,
                      message: str) -> None:
        with self._lock:
            if self._bar is None or self._bar_total != total or self._bar_desc != message:
                if self._bar is not None:
                    self._bar.close()
                self._bar = ProgressBar(
                    total=total, desc=message,
                    logger=self._logger, disable=False,
                )
                self._bar_total = total
                self._bar_desc = message
            self._bar.update(1)

    def finish_progress(self) -> None:
        """Close the current progress bar if active."""
        with self._lock:
            if self._bar is not None:
                self._bar.close()
                self._bar = None
                self._bar_total = 0
                self._bar_desc = ""

    def show_status(self, message: str,
                    level: str = "info") -> None:
        print(message)

    def show_banner(self, title: str,
                    subtitle: str | None = None) -> None:
        width = max(len(title), 62)
        title_padded = title.ljust(width)
        print(f"\n╔{'═' * width}╗")
        print(f"║{title_padded}║")
        print(f"╚{'═' * width}╝\n")
        if subtitle:
            print(f"  {subtitle}")



