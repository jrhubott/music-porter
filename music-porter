def _create_usb_args_parser():
    """Create shared parent parser for USB-related arguments."""
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument('--usb-dir', default=None,
                        help=f'USB directory (default: {DEFAULT_USB_DIR})')
    return parser


def positive_int(value):
    """Argparse type for positive integers (1+)."""
    try:
        ivalue = int(value)
    except ValueError as e:
        raise argparse.ArgumentTypeError(f"'{value}' is not a valid integer") from e
    if ivalue < 1:
        raise argparse.ArgumentTypeError(f"'{value}' is not a positive integer (must be >= 1)")
    return ivalue


