def _format_size_for_renderer(bytes_size: int) -> str:
    """Format bytes to human-readable size (shared by renderers)."""
    if bytes_size < 1024:
        return f"{bytes_size} B"
    elif bytes_size < 1024 * 1024:
        return f"{bytes_size / 1024:.1f} KB"
    elif bytes_size < 1024 * 1024 * 1024:
        return f"{bytes_size / (1024 * 1024):.1f} MB"
    else:
        return f"{bytes_size / (1024 * 1024 * 1024):.1f} GB"


def _get_freshness(last_modified: datetime | None, today: date) -> tuple[str, str]:
    """Return (icon, level_name) for a playlist's last_modified date."""
    if not last_modified:
        return ("❌", "outdated")
    age_days = (today - last_modified.date()).days
    if age_days <= FRESHNESS_CURRENT_DAYS:
        return ("✅", "current")
    elif age_days <= FRESHNESS_RECENT_DAYS:
        return ("", "recent")
    elif age_days <= FRESHNESS_STALE_DAYS:
        return ("⚠️", "stale")
    else:
        return ("❌", "outdated")


