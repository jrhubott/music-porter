def handle_config_command(args, config, config_load_error, config_parser):
    """Handle all config subcommand actions."""
    action = getattr(args, 'config_action', None)

    if action is None:
        # Bare "config" — print help (which includes CONFIG_HELP_TEXT as epilog)
        config_parser.print_help()
        sys.exit(0)

    if action == 'verify':
        results = validate_config(DEFAULT_CONFIG_FILE)

        # If the config failed to load at startup, add that context
        if config_load_error:
            results.insert(0, ("error", f"Config load failed: {config_load_error}"))

        errors = sum(1 for level, _ in results if level == "error")
        warnings = sum(1 for level, _ in results if level == "warning")
        oks = sum(1 for level, _ in results if level == "ok")

        print(f"\n  Config Verification: {DEFAULT_CONFIG_FILE}")
        print(f"  {'─' * 55}")
        for level, message in results:
            if level == "ok":
                icon = "✓"
            elif level == "warning":
                icon = "⚠"
            else:
                icon = "✗"
            print(f"  {icon} {message}")

        print(f"  {'─' * 55}")
        parts = []
        if oks:
            parts.append(f"{oks} passed")
        if warnings:
            parts.append(f"{warnings} warning(s)")
        if errors:
            parts.append(f"{errors} error(s)")
        print(f"  Result: {', '.join(parts)}\n")

        sys.exit(1 if errors else 0)

    if action == 'reset':
        config_path = Path(DEFAULT_CONFIG_FILE)

        if not getattr(args, 'force', False):
            print("\n  This will reset config.yaml to defaults.")
            if config_path.exists():
                print("  Your current config (including playlists) will be backed up.")
            try:
                response = input("  Continue? [y/N] ").strip().lower()
            except (EOFError, KeyboardInterrupt):
                print("\n  Cancelled.")
                sys.exit(0)
            if response != 'y':
                print("  Cancelled.")
                sys.exit(0)

        # Backup existing config
        backup_path = None
        if config_path.exists():
            import shutil
            backup_path = Path(f"{DEFAULT_CONFIG_FILE}.backup")
            shutil.copy2(config_path, backup_path)
            config_path.unlink()

        # Recreate with defaults
        temp_logger = Logger(verbose=False)
        ConfigManager(logger=temp_logger)

        print(f"\n  Config reset to defaults: {DEFAULT_CONFIG_FILE}")
        if backup_path:
            print(f"  Backup saved: {backup_path}")
        print()
        sys.exit(0)

    CONFIGURABLE_KEYS = {'output_type', 'usb_dir', 'workers', 'external_url', 'server_name'}

    if action == 'get':
        if config_load_error:
            print(f"  Error: {config_load_error}")
            sys.exit(1)
        key = args.key
        if key == 'api_key':
            print("  Error: use './music-porter server --show-api-key' to view the API key")
            sys.exit(1)
        if key not in CONFIGURABLE_KEYS:
            print(f"  Error: unknown setting '{key}'")
            print(f"  Valid keys: {', '.join(sorted(CONFIGURABLE_KEYS))}")
            sys.exit(1)
        value = config.get_setting(key)
        if value is not None:
            print(f"  {key} = {value}")
        else:
            print(f"  {key} = (not set)")
        sys.exit(0)

    if action == 'set':
        if config_load_error:
            print(f"  Error: {config_load_error}")
            sys.exit(1)
        key = args.key
        value = args.value
        if key not in CONFIGURABLE_KEYS:
            print(f"  Error: unknown setting '{key}'")
            print(f"  Valid keys: {', '.join(sorted(CONFIGURABLE_KEYS))}")
            sys.exit(1)
        # Type conversion and validation
        if key == 'workers':
            try:
                value = int(value)
            except ValueError:
                print(f"  Error: workers must be an integer, got '{value}'")
                sys.exit(1)
            if value < 1:
                print(f"  Error: workers must be >= 1, got {value}")
                sys.exit(1)
        if key == 'output_type':
            valid_profiles = list(OUTPUT_PROFILES.keys())
            if value not in valid_profiles:
                print(f"  Error: unknown profile '{value}'")
                print(f"  Valid profiles: {', '.join(valid_profiles)}")
                sys.exit(1)
        config.update_setting(key, value)
        print(f"  {key} = {value}")
        sys.exit(0)


